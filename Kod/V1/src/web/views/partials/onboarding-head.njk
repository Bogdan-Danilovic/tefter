<div class="mb-6">
  <p class="text-[13px] font-medium text-muted">{{ s.name }} · korak {{ step }} od 3</p>
  <h1 class="mt-0.5 text-xl font-semibold tracking-tight">{{ heading }}</h1>
  <p class="mt-1 text-sm text-muted">{{ sub }}</p>
  <div class="mt-3 flex gap-1.5">
    {% for i in [1, 2, 3] %}
    <span class="h-1 flex-1 rounded-full {% if i <= step %}bg-ink{% else %}bg-ink/15{% endif %}"></span>
    {% endfor %}
  </div>
</div>
