<!doctype html>
<html lang="sr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover, interactive-widget=resizes-content" />
    <title>{% block title %}Tefter{% endblock %}</title>
    <link rel="stylesheet" href="/app.css" />

    <!-- PWA -->
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#f5f4f1" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="Tefter" />
    <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />
    <link rel="icon" type="image/png" href="/icons/icon-192.png" />
  </head>
  <body class="min-h-screen">
    {% block content %}{% endblock %}

    {% if salon %}
    <!-- Bottom navigacija (app shell) -->
    <nav class="bottom-nav">
      <div class="bottom-nav-inner">
        <a href="/s/{{ salon.slug }}/day" class="bottom-nav-item bottom-nav-active">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
          <span>Danas</span>
        </a>
        <button type="button" class="bottom-nav-item" onclick="tefterToast('Klijenti — uskoro')">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          <span>Klijenti</span>
        </button>
        <button type="button" class="bottom-nav-item" onclick="tefterToast('Statistika — uskoro')">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="M7 15l4-6 4 3 5-8"/></svg>
          <span>Statistika</span>
        </button>
        <button type="button" class="bottom-nav-item" onclick="tefterToast('Podešavanja — uskoro')">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="1.6"/><circle cx="5" cy="12" r="1.6"/><circle cx="19" cy="12" r="1.6"/></svg>
          <span>Više</span>
        </button>
      </div>
    </nav>
    {% endif %}

    <!-- HTMX ciljevi na nivou stranice -->
    <div id="modal"></div>
    <div id="flash" class="pointer-events-none fixed inset-x-0 z-[60] flex justify-center px-4"
         style="bottom: calc(4.75rem + env(safe-area-inset-bottom))"></div>

    <script src="/app.js"></script>
    <script src="/vendor/htmx.min.js"></script>
    <script defer src="/vendor/alpine.min.js"></script>
  </body>
</html>
