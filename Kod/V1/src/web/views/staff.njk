{% extends "layout.njk" %}
{% block title %}Radnici · {{ salon.name }}{% endblock %}
{% block content %}
{% include "partials/page-head.njk" %}

<main class="mx-auto w-full max-w-3xl px-4 pt-4"
      style="padding-bottom: calc(6.5rem + env(safe-area-inset-bottom))"
      x-data="{ novi: false, edit: null }">

  <div class="flex items-center justify-between">
    <p class="text-[13px] text-muted">Boja radnika se vidi na kartici termina u kalendaru.</p>
    <button type="button" class="btn btn-ghost flex-none text-[13px]" @click="novi = !novi">+ Novi</button>
  </div>

  <form x-show="novi" x-cloak method="post" action="/s/{{ salon.slug }}/radnici"
        class="mt-2 rounded-xl border border-line bg-surface p-4" style="display:none">
    <label class="field-label" for="stf-name">Ime</label>
    <input class="field" id="stf-name" name="fullName" required maxlength="60" placeholder="npr. Ana" />
    <p class="field-label mt-3">Boja</p>
    <div class="flex flex-wrap gap-2">
      {% for c in palette %}
      <label class="cursor-pointer">
        <input type="radio" name="color" value="{{ c }}" class="peer sr-only" {% if loop.first %}checked{% endif %} />
        <span class="block h-9 w-9 rounded-full ring-2 ring-transparent peer-checked:ring-ink" style="background:{{ c }}"></span>
      </label>
      {% endfor %}
    </div>
    <button type="submit" class="btn btn-primary mt-4 w-full sm:w-auto">Dodaj radnika</button>
  </form>

  {% if error %}
  <p class="mt-3 rounded-lg bg-now/10 px-3 py-2.5 text-sm text-now">{{ error }}</p>
  {% endif %}

  <ul class="mt-4 divide-y divide-line overflow-hidden rounded-xl border border-line bg-surface">
    {% for s in items %}
    <li class="px-4 py-3 {% if not s.isActive %}opacity-55{% endif %}">
      <div class="flex items-center gap-3">
        <span class="h-3.5 w-3.5 flex-none rounded-full" style="background:{{ s.color }}"></span>
        <span class="min-w-0 flex-1 truncate text-[15px] font-medium">
          {{ s.fullName }}{% if not s.isActive %} <span class="text-[12px] font-normal text-muted">(neaktivan)</span>{% endif %}
        </span>
        <button type="button" class="btn btn-ghost flex-none px-2 text-[13px]"
                @click="edit = (edit === '{{ s.id }}' ? null : '{{ s.id }}')">Izmeni</button>
      </div>

      <form x-show="edit === '{{ s.id }}'" x-cloak method="post"
            action="/s/{{ salon.slug }}/radnici/{{ s.id }}" class="mt-3 border-t border-line pt-3" style="display:none">
        <label class="field-label">Ime</label>
        <input class="field" name="fullName" value="{{ s.fullName }}" required maxlength="60" />
        <p class="field-label mt-3">Boja</p>
        <div class="flex flex-wrap gap-2">
          {% for c in palette %}
          <label class="cursor-pointer">
            <input type="radio" name="color" value="{{ c }}" class="peer sr-only" {% if c == s.color %}checked{% endif %} />
            <span class="block h-9 w-9 rounded-full ring-2 ring-transparent peer-checked:ring-ink" style="background:{{ c }}"></span>
          </label>
          {% endfor %}
        </div>
        <label class="mt-3 flex items-center gap-2 text-sm">
          <input type="checkbox" name="isActive" value="1" class="h-5 w-5 rounded border-line" {% if s.isActive %}checked{% endif %} />
          Aktivan (nudi se pri zakazivanju)
        </label>
        <button type="submit" class="btn btn-primary mt-3 w-full sm:w-auto">Sačuvaj</button>
      </form>
    </li>
    {% else %}
    <li class="px-4 py-10 text-center text-sm text-muted">Nema radnika — termini idu na „Bilo ko".</li>
    {% endfor %}
  </ul>
</main>
{% endblock %}
