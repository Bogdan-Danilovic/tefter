{% extends "layout.njk" %}
{% block title %}Statistika · {{ salon.name }}{% endblock %}
{% block content %}
{% include "partials/page-head.njk" %}

<main class="mx-auto w-full max-w-3xl px-4 pt-4"
      style="padding-bottom: calc(6.5rem + env(safe-area-inset-bottom))">

  <div class="flex gap-1 rounded-xl border border-line bg-surface p-1">
    {% for p in periods %}
    <a href="/s/{{ salon.slug }}/statistika?period={{ p.key }}"
       class="flex-1 rounded-lg py-2 text-center text-[13px] font-medium {% if p.key == period %}bg-ink text-white{% else %}text-muted{% endif %}">
      {{ p.label }}
    </a>
    {% endfor %}
  </div>
  <p class="mt-2 text-center text-[13px] text-muted">{{ rangeLabel }}</p>

  <div class="mt-4 grid grid-cols-2 gap-2">
    <div class="rounded-xl border border-line bg-surface px-4 py-3">
      <p class="text-[11px] uppercase tracking-wide text-muted">Promet</p>
      <p class="mt-1 text-[22px] font-semibold tabular-nums">{{ summary.revenue | rsd }}</p>
    </div>
    <div class="rounded-xl border border-line bg-surface px-4 py-3">
      <p class="text-[11px] uppercase tracking-wide text-muted">Termina</p>
      <p class="mt-1 text-[22px] font-semibold tabular-nums">{{ summary.done }}</p>
    </div>
    <div class="rounded-xl border border-line bg-surface px-4 py-3">
      <p class="text-[11px] uppercase tracking-wide text-muted">Klijenata</p>
      <p class="mt-1 text-[22px] font-semibold tabular-nums">{{ summary.clients }}</p>
    </div>
    <div class="rounded-xl border border-line bg-surface px-4 py-3">
      <p class="text-[11px] uppercase tracking-wide text-muted">Otkazano</p>
      <p class="mt-1 text-[22px] font-semibold tabular-nums {% if summary.cancelled %}text-now{% endif %}">{{ summary.cancelled }}</p>
    </div>
  </div>

  {% if byDay|length %}
  <section class="mt-4 rounded-xl border border-line bg-surface p-4">
    <h2 class="text-[15px] font-semibold">Po danima</h2>
    {# Stubići: kolona ima definisanu visinu (h-28) pa procenat na traci ima na šta da se osloni. #}
    <div class="mt-4 flex h-28 gap-1">
      {% for d in byDay %}
      <div class="flex h-full flex-1 flex-col justify-end" title="{{ d.label }}: {{ d.revenue | rsd }}">
        <span class="w-full rounded-t bg-ink/80" style="height: {{ d.pct }}%; min-height: 2px"></span>
      </div>
      {% endfor %}
    </div>
    <div class="mt-1 flex gap-1">
      {% for d in byDay %}
      <span class="flex-1 text-center text-[10px] text-muted">{{ d.short }}</span>
      {% endfor %}
    </div>
    <p class="mt-3 text-[13px] text-muted">Najjači dan: <span class="font-medium text-ink">{{ bestDay }}</span></p>
  </section>
  {% endif %}

  <section class="mt-4">
    <h2 class="text-[15px] font-semibold">Po radniku</h2>
    <ul class="mt-2 divide-y divide-line overflow-hidden rounded-xl border border-line bg-surface">
      {% for r in byStaff %}
      <li class="flex items-center gap-3 px-4 py-3">
        <span class="h-3 w-3 flex-none rounded-full" style="background:{{ r.color }}"></span>
        <span class="min-w-0 flex-1 truncate text-[15px]">{{ r.name }}</span>
        <span class="flex-none text-right">
          <span class="block text-[14px] font-medium tabular-nums">{{ r.revenue | rsd }}</span>
          <span class="block text-[12px] text-muted">{{ r.done | plural("termin", "termina", "termina") }}</span>
        </span>
      </li>
      {% else %}
      <li class="px-4 py-8 text-center text-sm text-muted">Nema termina u ovom periodu.</li>
      {% endfor %}
    </ul>
  </section>

  <section class="mt-4">
    <h2 class="text-[15px] font-semibold">Po usluzi</h2>
    <ul class="mt-2 divide-y divide-line overflow-hidden rounded-xl border border-line bg-surface">
      {% for r in byService %}
      <li class="flex items-center gap-3 px-4 py-3">
        <span class="min-w-0 flex-1 truncate text-[15px]">{{ r.name }}</span>
        <span class="flex-none text-right">
          <span class="block text-[14px] font-medium tabular-nums">{{ r.revenue | rsd }}</span>
          <span class="block text-[12px] text-muted">{{ r.done }}×</span>
        </span>
      </li>
      {% else %}
      <li class="px-4 py-8 text-center text-sm text-muted">Nema termina u ovom periodu.</li>
      {% endfor %}
    </ul>
  </section>
</main>
{% endblock %}
