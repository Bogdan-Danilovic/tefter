{% extends "layout.njk" %}
{% block title %}Usluge · {{ salon.name }}{% endblock %}
{% block content %}
{% include "partials/page-head.njk" %}

<main class="mx-auto w-full max-w-3xl px-4 pt-4"
      style="padding-bottom: calc(6.5rem + env(safe-area-inset-bottom))"
      x-data="{ nova: false, edit: null }">

  <div class="flex items-center justify-between">
    <p class="text-[13px] text-muted">Trajanje i cena se automatski povlače u novi termin. Boja usluge se vidi na kartici termina u kalendaru.</p>
    <button type="button" class="btn btn-ghost flex-none text-[13px]" @click="nova = !nova">+ Nova</button>
  </div>

  <form x-show="nova" x-cloak method="post" action="/s/{{ salon.slug }}/usluge"
        class="mt-2 rounded-xl border border-line bg-surface p-4" style="display:none">
    <div class="flex flex-col gap-3 sm:flex-row">
      <div class="flex-1">
        <label class="field-label" for="svc-name">Naziv</label>
        <input class="field" id="svc-name" name="name" required maxlength="60" placeholder="npr. Šišanje" />
      </div>
      <div class="w-full sm:w-32">
        <label class="field-label" for="svc-dur">Trajanje (min)</label>
        <input class="field" id="svc-dur" name="durationMin" inputmode="numeric" required value="30" />
      </div>
      <div class="w-full sm:w-32">
        <label class="field-label" for="svc-price">Cena (RSD)</label>
        <input class="field" id="svc-price" name="price" inputmode="numeric" required value="1000" />
      </div>
    </div>
    <p class="field-label mt-3">Boja</p>
    <div class="flex flex-wrap gap-2">
      {% for c in palette %}
      <label class="cursor-pointer">
        <input type="radio" name="color" value="{{ c }}" class="peer sr-only" {% if loop.first %}checked{% endif %} />
        <span class="block h-9 w-9 rounded-full ring-2 ring-transparent peer-checked:ring-ink" style="background:{{ c }}"></span>
      </label>
      {% endfor %}
    </div>
    <button type="submit" class="btn btn-primary mt-4 w-full sm:w-auto">Dodaj uslugu</button>
  </form>

  {% if error %}
  <p class="mt-3 rounded-lg bg-now/10 px-3 py-2.5 text-sm text-now">{{ error }}</p>
  {% endif %}

  <ul class="mt-4 divide-y divide-line overflow-hidden rounded-xl border border-line bg-surface">
    {% for s in items %}
    <li class="px-4 py-3 {% if not s.isActive %}opacity-55{% endif %}">
      <div class="flex items-center gap-3">
        <span class="h-3.5 w-3.5 flex-none rounded-full" style="background:{{ s.color }}"></span>
        <span class="min-w-0 flex-1">
          <span class="block truncate text-[15px] font-medium">
            {{ s.name }}{% if not s.isActive %} <span class="text-[12px] font-normal text-muted">(neaktivna)</span>{% endif %}
          </span>
          <span class="block text-[13px] text-muted tabular-nums">{{ s.defaultDurationMin }} min · {{ s.defaultPrice | rsd }}</span>
        </span>
        <button type="button" class="btn btn-ghost flex-none px-2 text-[13px]"
                @click="edit = (edit === '{{ s.id }}' ? null : '{{ s.id }}')">Izmeni</button>
      </div>

      <form x-show="edit === '{{ s.id }}'" x-cloak method="post"
            action="/s/{{ salon.slug }}/usluge/{{ s.id }}" class="mt-3 border-t border-line pt-3" style="display:none">
        <div class="flex flex-col gap-3 sm:flex-row">
          <div class="flex-1">
            <label class="field-label">Naziv</label>
            <input class="field" name="name" value="{{ s.name }}" required maxlength="60" />
          </div>
          <div class="w-full sm:w-32">
            <label class="field-label">Trajanje (min)</label>
            <input class="field" name="durationMin" inputmode="numeric" value="{{ s.defaultDurationMin }}" required />
          </div>
          <div class="w-full sm:w-32">
            <label class="field-label">Cena (RSD)</label>
            <input class="field" name="price" inputmode="numeric" value="{{ s.priceInput }}" required />
          </div>
        </div>
        <p class="field-label mt-3">Boja</p>
        <div class="flex flex-wrap gap-2">
          {% for c in palette %}
          <label class="cursor-pointer">
            <input type="radio" name="color" value="{{ c }}" class="peer sr-only" {% if c == s.color %}checked{% endif %} />
            <span class="block h-9 w-9 rounded-full ring-2 ring-transparent peer-checked:ring-ink" style="background:{{ c }}"></span>
          </label>
          {% endfor %}
        </div>
        <label class="mt-3 flex items-center gap-2 text-sm">
          <input type="checkbox" name="isActive" value="1" class="h-5 w-5 rounded border-line" {% if s.isActive %}checked{% endif %} />
          Aktivna (nudi se pri zakazivanju)
        </label>
        <button type="submit" class="btn btn-primary mt-3 w-full sm:w-auto">Sačuvaj</button>
      </form>
    </li>
    {% else %}
    <li class="px-4 py-10 text-center text-sm text-muted">Nema usluga — dodaj prvu.</li>
    {% endfor %}
  </ul>
</main>
{% endblock %}
