{% extends "marketing.njk" %}
{% block title %}Tefter — rokovnik tvog salona, u telefonu{% endblock %}
{% block content %}

<header class="sticky top-0 z-40 border-b border-line/70 bg-bg/85 backdrop-blur">
  <div class="mx-auto flex h-14 max-w-5xl items-center justify-between px-5">
    <a href="/" class="text-[19px] font-semibold tracking-tight">Tefter<span class="text-now">.</span></a>
    <nav class="flex items-center gap-1">
      {% if session %}
      <a href="/s/{{ session.slug }}/day" class="btn btn-primary">Otvori aplikaciju</a>
      {% else %}
      <a href="/prijava" class="btn btn-ghost">Prijava</a>
      <a href="/registracija" class="btn btn-primary">Probaj besplatno</a>
      {% endif %}
    </nav>
  </div>
</header>

<!-- ── Hero ──────────────────────────────────────────────────────────────── -->
<section class="mx-auto max-w-5xl px-5 pb-4 pt-12 sm:pt-20">
  <div class="grid items-center gap-12 sm:grid-cols-2 sm:gap-8">
    <div>
      <p class="mb-4 inline-flex items-center gap-2 rounded-full border border-line bg-surface px-3 py-1 text-xs font-medium text-muted">
        <span class="h-1.5 w-1.5 rounded-full bg-now"></span> Za frizerske i kozmetičke salone
      </p>
      <h1 class="text-[34px] font-semibold leading-[1.1] tracking-tight sm:text-[44px]">
        Rokovnik tvog salona,<br class="hidden sm:block" /> u telefonu.
      </h1>
      <p class="mt-4 max-w-md text-[17px] leading-relaxed text-muted">
        Zakazivanje, klijenti i dnevni pregled na jednom mestu — bez sveske,
        bez izgubljenih termina, bez papira. Otvoriš i radi.
      </p>
      <div class="mt-7 flex flex-col gap-3 sm:flex-row">
        <a href="/registracija" class="btn btn-primary h-12 px-6 text-[15px] sm:h-12">Otvori salon besplatno</a>
        <a href="#kako-radi" class="btn h-12 border border-line bg-surface px-6 text-[15px] sm:h-12">Vidi kako radi</a>
      </div>
      <p class="mt-3 text-xs text-muted">Bez kartice · Podešavanje traje 2 minuta · Radi na svakom telefonu</p>
    </div>

    <!-- Mockup telefona: isti stil kao prava aplikacija -->
    <div class="mx-auto w-full max-w-[280px]">
      <div class="rounded-[2rem] border border-line-strong bg-surface p-2 shadow-modal">
        <div class="overflow-hidden rounded-[1.5rem] bg-bg">
          <div class="px-4 pb-2 pt-4">
            <p class="text-[11px] text-muted">Salon Demo</p>
            <p class="text-[17px] font-semibold tracking-tight">Sub 18.07.</p>
          </div>
          <div class="flex gap-1 px-3 pb-3">
            {% for d in ["pon","uto","sre","čet","pet","sub","ned"] %}
            <div class="flex-1 rounded-md px-1 py-1 text-center text-[9px] {% if d == 'sub' %}bg-ink text-white{% else %}text-muted{% endif %}">{{ d }}</div>
            {% endfor %}
          </div>
          <div class="space-y-2 border-t border-line px-3 py-3">
            <div class="flex overflow-hidden rounded-lg bg-surface shadow-card ring-1 ring-line">
              <span class="w-[3px] flex-none bg-[#e0912f]"></span>
              <span class="px-2 py-1.5">
                <span class="block text-[9px] text-muted">10:00–11:30</span>
                <span class="block text-[11px] font-medium leading-tight">Milica Petrović</span>
                <span class="block text-[9px] text-muted">Farbanje · Ana</span>
              </span>
            </div>
            <div class="ml-6 flex overflow-hidden rounded-lg bg-surface shadow-card ring-1 ring-line">
              <span class="w-[3px] flex-none bg-[#2f8f5b]"></span>
              <span class="px-2 py-1.5">
                <span class="block text-[9px] text-muted">12:00–12:30</span>
                <span class="block text-[11px] font-medium leading-tight">Teodora Ilić</span>
                <span class="block text-[9px] text-muted">Feniranje · Jelena</span>
              </span>
            </div>
            <div class="flex overflow-hidden rounded-lg bg-surface shadow-card ring-1 ring-line">
              <span class="w-[3px] flex-none bg-[#3b6fd4]"></span>
              <span class="px-2 py-1.5">
                <span class="block text-[9px] text-muted">13:30–14:15</span>
                <span class="block text-[11px] font-medium leading-tight">Jovana Nikolić</span>
                <span class="block text-[9px] text-muted">Šišanje · Marija</span>
              </span>
            </div>
          </div>
          <div class="flex items-center justify-around border-t border-line bg-surface px-2 py-2 text-[9px] text-muted">
            <span class="font-medium text-ink">Danas</span><span>Klijenti</span><span>Statistika</span><span>Više</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ── Problem → rešenje ─────────────────────────────────────────────────── -->
<section class="mx-auto max-w-5xl px-5 py-14">
  <div class="rounded-2xl border border-line bg-surface p-6 sm:p-8">
    <p class="text-sm font-medium text-muted">Poznato?</p>
    <p class="mt-2 max-w-2xl text-[19px] leading-relaxed sm:text-[22px]">
      Sveska ostane u salonu. Klijentkinja zove dok si na pauzi. Dva termina u isto vreme.
      Ne znaš koliko si zaradila ovog meseca dok ne sedneš i ne prebrojiš.
    </p>
    <p class="mt-4 max-w-2xl text-[15px] text-muted">
      Tefter drži sve to na jednom mestu — u telefonu koji ti je ionako u džepu.
    </p>
  </div>
</section>

<!-- ── Feature sekcije ───────────────────────────────────────────────────── -->
<section id="kako-radi" class="mx-auto max-w-5xl px-5 pb-6">
  <h2 class="text-[26px] font-semibold tracking-tight sm:text-[32px]">Sve što salon stvarno koristi</h2>
  <div class="mt-8 grid gap-4 sm:grid-cols-2">

    <article class="rounded-2xl border border-line bg-surface p-6">
      <svg class="h-6 w-6 text-ink" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
      <h3 class="mt-4 text-[17px] font-semibold">Dnevni kalendar koji se čita iz prve</h3>
      <p class="mt-2 text-[15px] leading-relaxed text-muted">
        Svaki radnik svoju boju, preklapanja odmah vidljiva, prevlačenjem menjaš dan.
        Novi termin je jedan tap na „+“.
      </p>
    </article>

    <article class="rounded-2xl border border-line bg-surface p-6">
      <svg class="h-6 w-6 text-ink" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/></svg>
      <h3 class="mt-4 text-[17px] font-semibold">Kartoteka klijenata</h3>
      <p class="mt-2 text-[15px] leading-relaxed text-muted">
        Istorija dolazaka, beleške (formula boje, alergije), ukupna potrošnja.
        Poziv i SMS su jedan tap iz kartona.
      </p>
    </article>

    <article class="rounded-2xl border border-line bg-surface p-6">
      <svg class="h-6 w-6 text-ink" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="6" y="2" width="12" height="20" rx="2"/><path d="M11 18h2"/></svg>
      <h3 class="mt-4 text-[17px] font-semibold">Radi kao prava aplikacija</h3>
      <p class="mt-2 text-[15px] leading-relaxed text-muted">
        Dodaš je na početni ekran telefona i otvara se bez browsera.
        Nema instalacije sa prodavnice, nema ažuriranja koja te muče.
      </p>
    </article>

    <article class="rounded-2xl border border-line bg-surface p-6">
      <svg class="h-6 w-6 text-ink" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="M7 15l4-6 4 3 5-8"/></svg>
      <h3 class="mt-4 text-[17px] font-semibold">Znaš svoj promet</h3>
      <p class="mt-2 text-[15px] leading-relaxed text-muted">
        Koliko je urađeno danas, ove nedelje, ovog meseca — po radniku i po usluzi.
        Bez ručnog sabiranja.
      </p>
    </article>
  </div>
</section>

<!-- ── Online zakazivanje (hero feature) ─────────────────────────────────── -->
<section class="mx-auto max-w-5xl px-5 py-14">
  <div class="rounded-2xl bg-ink p-7 text-white sm:p-10">
    <p class="text-xs font-medium uppercase tracking-wide text-white/60">Pro</p>
    <h2 class="mt-2 max-w-lg text-[26px] font-semibold leading-tight tracking-tight sm:text-[32px]">
      Klijentkinje se zakazuju same, dok ti radiš
    </h2>
    <p class="mt-4 max-w-xl text-[15px] leading-relaxed text-white/70">
      Dobiješ svoj link (npr. <span class="text-white">tefter.rs/s/tvoj-salon/zakazi</span>) i staviš ga u
      Instagram bio. Klijentkinja bira uslugu, vidi stvarno slobodne termine i ostavlja ime i broj.
      Ti samo potvrdiš — bez dopisivanja u porukama u 23h.
    </p>
  </div>
</section>

<!-- ── Cenovnik ──────────────────────────────────────────────────────────── -->
<section id="cenovnik" class="mx-auto max-w-5xl px-5 py-6">
  <h2 class="text-[26px] font-semibold tracking-tight sm:text-[32px]">Cena</h2>
  <p class="mt-2 text-[15px] text-muted">Počni besplatno. Pređi na Pro kad ti zatreba više.</p>

  <div class="mt-8 grid gap-4 sm:grid-cols-2">
    <div class="flex flex-col rounded-2xl border border-line bg-surface p-6">
      <p class="text-sm font-medium text-muted">Free</p>
      <p class="mt-2 text-[32px] font-semibold tracking-tight">0 <span class="text-base font-normal text-muted">RSD</span></p>
      <p class="mt-1 text-sm text-muted">Zauvek, bez kartice.</p>
      <ul class="mt-5 flex-1 space-y-2.5 text-[15px]">
        {% for f in freeFeatures %}
        <li class="flex gap-2.5"><span class="mt-[3px] text-muted">✓</span><span>{{ f }}</span></li>
        {% endfor %}
      </ul>
      <a href="/registracija" class="btn mt-6 h-12 border border-line bg-bg text-[15px] sm:h-12">Otvori salon</a>
    </div>

    <div class="flex flex-col rounded-2xl border-2 border-ink bg-surface p-6">
      <div class="flex items-center justify-between">
        <p class="text-sm font-medium">Pro</p>
        <span class="rounded-full bg-ink px-2.5 py-1 text-[11px] font-medium text-white">Najkorisnije</span>
      </div>
      <p class="mt-2 text-[32px] font-semibold tracking-tight">
        {{ pricing.proMonthly }} <span class="text-base font-normal text-muted">RSD / mesec</span>
      </p>
      <p class="mt-1 text-sm text-muted">{{ pricing.note }}</p>
      <ul class="mt-5 flex-1 space-y-2.5 text-[15px]">
        {% for f in proFeatures %}
        <li class="flex gap-2.5"><span class="mt-[3px] text-now">✓</span><span>{{ f }}</span></li>
        {% endfor %}
      </ul>
      <a href="/registracija" class="btn btn-primary mt-6 h-12 text-[15px] sm:h-12">Probaj Pro</a>
    </div>
  </div>
  <p class="mt-4 text-xs text-muted">
    Plaćanje uplatnicom ili prenosom na osnovu predračuna. Bez ugovora — prestaneš kad hoćeš.
  </p>
</section>

<!-- ── FAQ ───────────────────────────────────────────────────────────────── -->
<section class="mx-auto max-w-5xl px-5 py-14">
  <h2 class="text-[26px] font-semibold tracking-tight sm:text-[32px]">Česta pitanja</h2>
  <div class="mt-6 divide-y divide-line border-y border-line">
    {% for qa in faq %}
    <details class="group py-4">
      <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-[16px] font-medium">
        {{ qa.q }}
        <span class="text-muted transition group-open:rotate-45">+</span>
      </summary>
      <p class="mt-3 max-w-2xl text-[15px] leading-relaxed text-muted">{{ qa.a }}</p>
    </details>
    {% endfor %}
  </div>
</section>

<!-- ── Finalni CTA ───────────────────────────────────────────────────────── -->
<section class="mx-auto max-w-5xl px-5 pb-16">
  <div class="rounded-2xl border border-line bg-surface p-8 text-center">
    <h2 class="text-[24px] font-semibold tracking-tight sm:text-[30px]">Prebaci svesku u telefon danas</h2>
    <p class="mx-auto mt-3 max-w-md text-[15px] text-muted">
      Registracija traje minut, a odmah te vodi kroz radno vreme, usluge i radnike.
    </p>
    <a href="/registracija" class="btn btn-primary mx-auto mt-6 h-12 px-7 text-[15px] sm:h-12">Otvori salon besplatno</a>
  </div>
</section>

<footer class="border-t border-line">
  <div class="mx-auto flex max-w-5xl flex-col gap-3 px-5 py-8 text-sm text-muted sm:flex-row sm:items-center sm:justify-between">
    <p class="font-medium text-ink">Tefter<span class="text-now">.</span></p>
    <nav class="flex gap-5">
      <a href="#cenovnik" class="hover:text-ink">Cenovnik</a>
      <a href="/prijava" class="hover:text-ink">Prijava</a>
      <a href="/registracija" class="hover:text-ink">Registracija</a>
    </nav>
    <p>© {{ year }} Tefter</p>
  </div>
</footer>
{% endblock %}
