{% extends "marketing.njk" %}
{% import "sites/_shared.njk" as shared %}
{% block title %}{{ site.name }} — zakazivanje i cenovnik{% endblock %}

{# Ornament između sekcija: tanka linija — romb — tanka linija. #}
{% macro orn() %}
<div class="ar-orn" aria-hidden="true"><span></span></div>
{% endmacro %}

{% block head %}
{{ shared.themeStyle(theme, demo) }}
<style>
  /* ====================================================================
     Izgled "Arkada": elegancija ogledala i lukova — svaka "fotografija"
     je prozor sa polukružnim vrhom, tanke linije, romb ornamenti,
     cenovnik sa tačkastim vođicama kao jelovnik. Za beauty salone koji
     žele otmen, buduarski ton bez tamnog editoriala.
     ==================================================================== */
  .ar-wrap { max-width: 64rem; margin-inline: auto; padding-inline: 1.25rem; }
  .ar-section { padding-block: 4.5rem; }
  .ar-surface { background: var(--s-surface); border-block: 1px solid var(--s-line); }
  .ar-h2 { font-size: clamp(1.9rem, 4.5vw, 2.8rem); line-height: 1.12; }
  .ar-h2 em, .ar-h1 em { font-style: italic; color: var(--brand); }

  /* luk: polukružni vrh, blago zaobljeno dno — potpis celog izgleda */
  .ar-arch { position: relative; overflow: hidden; border-radius: 999rem 999rem calc(var(--s-radius) * 0.55) calc(var(--s-radius) * 0.55); }
  .ar-arch > div { position: absolute; inset: -10%; transition: transform 1.2s cubic-bezier(0.22, 1, 0.36, 1); }
  .ar-arch:hover > div { transform: scale(1.07); }

  /* ornament: linija — romb — linija */
  .ar-orn { display: flex; align-items: center; gap: 0.9rem; max-width: 16rem; margin-inline: auto; color: var(--brand); padding-block: 0.4rem; }
  .ar-orn::before, .ar-orn::after { content: ""; height: 1px; flex: 1; background: var(--s-line); }
  .ar-orn > span { width: 0.45rem; height: 0.45rem; border: 1px solid currentColor; transform: rotate(45deg); }

  /* --- navigacija -------------------------------------------------------- */
  .ar-nav {
    position: fixed; inset-inline: 0; top: var(--demo-offset, 0); z-index: 50;
    border-bottom: 1px solid transparent;
    transition: background 0.4s ease, border-color 0.4s ease, backdrop-filter 0.4s ease;
  }
  .ar-nav.scrolled { background: color-mix(in srgb, var(--s-bg) 84%, transparent); backdrop-filter: blur(12px); border-color: var(--s-line); }
  .ar-nav-links { display: none; gap: 1.6rem; }
  @media (min-width: 768px) { .ar-nav-links { display: flex; } }
  .ar-nav-link { font-size: 12px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--s-muted); text-decoration: none; transition: color 0.25s; }
  .ar-nav-link:hover { color: var(--brand); }

  /* --- hero: tekst + veliki luk ------------------------------------------ */
  .ar-hero {
    position: relative; padding: calc(var(--demo-offset, 0px) + 7.5rem) 0 4.5rem;
    background:
      radial-gradient(80% 55% at 80% 0%, var(--s-aurora2), transparent 70%),
      radial-gradient(60% 45% at 10% 30%, var(--s-aurora3), transparent 70%);
  }
  .ar-hero-grid { display: grid; gap: 3rem; align-items: center; }
  @media (min-width: 900px) { .ar-hero-grid { grid-template-columns: 1.1fr 0.9fr; gap: 4rem; } }
  .ar-h1 { font-size: clamp(2.5rem, 7vw, 4.6rem); line-height: 1.08; font-weight: var(--s-display-weight); }
  .ar-hero-art { position: relative; width: min(21rem, 78vw); margin-inline: auto; }
  .ar-hero-art .ar-arch { aspect-ratio: 3 / 4; box-shadow: 0 30px 70px -35px rgba(0, 0, 0, 0.45); }
  .ar-hero-art::before {
    content: ""; position: absolute; inset: 0; transform: translate(-1.1rem, 1.1rem);
    border: 1px solid color-mix(in srgb, var(--brand) 45%, transparent);
    border-radius: 999rem 999rem calc(var(--s-radius) * 0.55) calc(var(--s-radius) * 0.55);
  }
  .ar-rise { opacity: 0; transform: translateY(18px); animation: ar-rise 1.2s cubic-bezier(0.22, 1, 0.36, 1) forwards; animation-delay: var(--d, 0s); }
  @keyframes ar-rise { to { opacity: 1; transform: none; } }

  /* --- o nama: dva mala luka + tekst -------------------------------------- */
  .ar-duo { display: flex; justify-content: center; gap: 1.4rem; }
  .ar-duo .ar-arch { width: min(10.5rem, 38vw); aspect-ratio: 3 / 4.4; }
  .ar-duo .ar-arch:last-child { transform: translateY(1.6rem); }

  /* --- cenovnik: jelovnik sa tačkastim vođicama ---------------------------- */
  .ar-menu { max-width: 40rem; margin-inline: auto; }
  .ar-menu-row { display: flex; align-items: baseline; gap: 0.9rem; padding: 0.95rem 0.3rem; }
  .ar-menu-row + .ar-menu-row { border-top: 1px solid var(--s-line); }
  .ar-menu-dots { flex: 1; border-bottom: 1px dotted color-mix(in srgb, var(--s-ink) 30%, transparent); transform: translateY(-4px); }
  .ar-menu-val { font-family: var(--s-display); font-size: 1.15rem; color: var(--brand); font-variant-numeric: tabular-nums; white-space: nowrap; }
  .ar-menu-row:hover .ar-menu-name { color: var(--brand); }

  /* --- galerija: arkada prozora -------------------------------------------- */
  .ar-gal { display: grid; gap: 1.6rem 1.2rem; grid-template-columns: repeat(2, 1fr); }
  @media (min-width: 768px) { .ar-gal { grid-template-columns: repeat(3, 1fr); gap: 2.2rem 1.6rem; } }
  .ar-gal figure { margin: 0; text-align: center; }
  .ar-gal .ar-arch { aspect-ratio: 3 / 4; box-shadow: 0 24px 55px -35px rgba(0, 0, 0, 0.4); }
  .ar-gal figcaption { margin-top: 0.85rem; font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--s-muted); }

  /* --- tim: portreti u lukovima --------------------------------------------- */
  .ar-team { display: flex; flex-wrap: wrap; justify-content: center; gap: 2.2rem; }
  .ar-member { text-align: center; }
  .ar-member .ar-arch {
    width: 8.5rem; aspect-ratio: 3 / 4; margin-inline: auto;
    display: flex; align-items: center; justify-content: center;
    transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .ar-member:hover .ar-arch { transform: translateY(-5px); }
  .ar-init { position: relative; font-family: var(--s-display); font-size: 2.1rem; color: #14110d; /* ink na pastelnoj boji radnika (podatak, ne tema) */ }

  /* --- radno vreme + kontakt ------------------------------------------------ */
  .ar-hours { max-width: 23rem; margin-inline: auto; }
  .ar-hours-row { display: flex; justify-content: space-between; gap: 1rem; padding: 0.68rem 0.4rem; font-size: 14px; font-variant-numeric: tabular-nums; }
  .ar-hours-row + .ar-hours-row { border-top: 1px solid var(--s-line); }
  .ar-hours-row.today { color: var(--brand); font-weight: 600; }
  .ar-hours-row.today .ar-day::before { content: "◆ "; font-size: 9px; vertical-align: 2px; }
  .ar-phone { font-family: var(--s-display); font-weight: var(--s-display-weight); font-size: clamp(2rem, 6vw, 3.2rem); color: var(--s-ink); text-decoration: none; transition: color 0.3s; font-variant-numeric: tabular-nums; }
  .ar-phone:hover { color: var(--brand); }

  @media (prefers-reduced-motion: reduce) {
    .ar-rise { opacity: 1 !important; transform: none !important; }
  }
</style>
{% endblock %}

{% block content %}
<div class="site st-grain">

  {% if demo %}{{ shared.demoBar(layoutList, themeList, layout, theme) }}{% endif %}

  <!-- Navigacija -->
  <nav class="ar-nav" data-nav>
    <div class="ar-wrap" style="display:flex;align-items:center;justify-content:space-between;gap:1rem;height:4.25rem">
      <a href="#vrh" style="text-decoration:none;color:inherit"><span class="st-serif" style="font-size:17px">{{ site.name }}</span></a>
      <div class="ar-nav-links">
        <a class="ar-nav-link" href="#onama">O nama</a>
        <a class="ar-nav-link" href="#cenovnik">Cenovnik</a>
        <a class="ar-nav-link" href="#galerija">Galerija</a>
        <a class="ar-nav-link" href="#kontakt">Kontakt</a>
      </div>
      <a class="st-btn st-btn-gold st-btn-shine" style="height:2.75rem;padding-inline:1.2rem;font-size:13px" href="tel:{{ site.phoneRaw }}">Zakaži</a>
    </div>
  </nav>

  <!-- Hero: tekst + veliki luk -->
  <header class="ar-hero" id="vrh" data-hero>
    <div class="ar-wrap ar-hero-grid">
      <div>
        <p class="st-kicker ar-rise">{{ site.tagline }}</p>
        <h1 class="st-serif ar-h1 ar-rise" style="--d:.12s;margin-top:1.3rem">Lepota, uokvirena <em>pažnjom.</em></h1>
        <p class="ar-rise" style="--d:.26s;margin-top:1.4rem;max-width:28rem;color:var(--s-muted);font-size:16px;line-height:1.7">{{ site.about }}</p>
        <div class="ar-rise" style="--d:.4s;margin-top:2.2rem;display:flex;flex-wrap:wrap;gap:.9rem">
          <a class="st-btn st-btn-gold st-btn-shine" href="tel:{{ site.phoneRaw }}">Zakaži termin</a>
          <a class="st-btn st-btn-ghost" href="#cenovnik">Pogledaj cenovnik</a>
        </div>
      </div>
      <div class="ar-hero-art ar-rise" style="--d:.3s">
        <figure class="ar-arch" style="margin:0"><div style="background:{{ gallery[0].art }}"></div></figure>
      </div>
    </div>
  </header>

  <!-- O nama -->
  <section class="ar-section ar-surface" id="onama">
    <div class="ar-wrap" style="text-align:center">
      <div class="ar-duo rev">
        <div class="ar-arch"><div style="background:{{ gallery[1].art }}"></div></div>
        <div class="ar-arch"><div style="background:{{ gallery[2].art }}"></div></div>
      </div>
      <p class="st-kicker rev" style="margin-top:2.6rem">O nama</p>
      <h2 class="st-serif ar-h2 rev" style="margin-top:1rem;margin-inline:auto;max-width:24ch">Zanat star koliko i lepota. <em>Pristup — nov.</em></h2>
      <p class="rev" style="margin-top:1.4rem;margin-inline:auto;max-width:36rem;color:var(--s-muted);font-size:16px;line-height:1.75">{{ site.aboutLong }}</p>
      <div style="margin-top:2.4rem;display:flex;justify-content:center;flex-wrap:wrap;gap:2.6rem">
        {% for f in site.facts %}
        <div class="rev" style="--d:{{ loop.index0 * 0.12 }}s">
          <p class="st-serif" style="font-size:2rem;color:var(--brand)">{{ f.n }}</p>
          <p style="font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:var(--s-muted);margin-top:.2rem">{{ f.label }}</p>
        </div>
        {% endfor %}
      </div>
    </div>
  </section>

  <!-- Cenovnik: jelovnik -->
  <section class="ar-section" id="cenovnik">
    <div class="ar-wrap">
      <div style="text-align:center">
        <p class="st-kicker rev">Cenovnik</p>
        <h2 class="st-serif ar-h2 rev" style="margin-top:1rem">Kao dobar jelovnik — <em>kratak i jasan.</em></h2>
      </div>
      {{ orn() }}
      <div class="ar-menu rev">
        {% for s in services %}
        <div class="ar-menu-row">
          <div>
            <p class="ar-menu-name" style="font-size:15px;transition:color .25s">{{ s.name }}</p>
            <p style="font-size:11px;color:var(--s-muted);margin-top:.15rem">{{ s.durationMin }} min</p>
          </div>
          <span class="ar-menu-dots" aria-hidden="true"></span>
          <span class="ar-menu-val">{{ s.price }}</span>
        </div>
        {% endfor %}
      </div>
      <p class="rev" style="margin-top:1.6rem;text-align:center;font-size:13px;color:var(--s-muted)">Cene su informativne — za duže tretmane javi nam se porukom pre termina.</p>
    </div>
  </section>

  <!-- Galerija: arkada prozora -->
  <section class="ar-section ar-surface" id="galerija">
    <div class="ar-wrap">
      <div style="text-align:center">
        <p class="st-kicker rev">Galerija</p>
        <h2 class="st-serif ar-h2 rev" style="margin-top:1rem">Svaki rad — <em>mali prozor.</em></h2>
      </div>
      <div class="ar-gal" style="margin-top:2.8rem">
        {% for g in gallery %}
        <figure class="rev" style="--d:{{ loop.index0 * 0.08 }}s">
          <div class="ar-arch"><div style="background:{{ g.art }}"></div></div>
          <figcaption>{{ g.label }}</figcaption>
        </figure>
        {% endfor %}
      </div>
    </div>
  </section>

  <!-- Tim -->
  <section class="ar-section" id="tim">
    <div class="ar-wrap" style="text-align:center">
      <p class="st-kicker rev">Tim</p>
      <h2 class="st-serif ar-h2 rev" style="margin-top:1rem">Ruke od poverenja.</h2>
      <div class="ar-team" style="margin-top:2.6rem">
        {% for m in staff %}
        <div class="ar-member rev" style="--d:{{ loop.index0 * 0.1 }}s">
          <div class="ar-arch"><div style="background:{{ m.color }};transition:none"></div><span class="ar-init">{{ m.initials }}</span></div>
          <p style="margin-top:1rem;font-size:16px;font-weight:600">{{ m.name }}</p>
          <p style="margin-top:.15rem;font-size:13px;color:var(--s-muted)">{{ m.role }}</p>
        </div>
        {% endfor %}
      </div>
    </div>
  </section>

  <!-- Radno vreme + kontakt -->
  <section class="ar-section ar-surface" id="kontakt" style="padding-bottom:3rem">
    <div class="ar-wrap" style="text-align:center">
      <p class="st-kicker rev">Radno vreme</p>
      <div class="ar-hours rev" style="margin-top:1.5rem">
        {% for h in hours %}
        <div class="ar-hours-row {% if h.today %}today{% endif %}">
          <span class="ar-day">{{ h.label }}</span>
          <span style="{% if not h.open %}color:var(--s-muted){% endif %}">{{ h.time }}</span>
        </div>
        {% endfor %}
      </div>

      {{ orn() }}
      <p class="st-kicker rev" style="margin-top:2.2rem">Kontakt</p>
      <h2 class="st-serif ar-h2 rev" style="margin-top:1rem">Vidimo se <em>u salonu.</em></h2>
      <a class="ar-phone rev" style="display:inline-block;margin-top:1.2rem" href="tel:{{ site.phoneRaw }}">{{ site.phone }}</a>
      <p class="rev" style="margin-top:.8rem;color:var(--s-muted);font-size:14px">
        <a href="https://www.google.com/maps/search/{{ site.address | urlencode }}" target="_blank" rel="noopener" style="color:inherit">{{ site.address }}</a>
      </p>
      <div class="rev" style="margin-top:1.8rem;display:flex;flex-wrap:wrap;gap:.9rem;justify-content:center">
        <a class="st-btn st-btn-gold st-btn-shine" href="tel:{{ site.phoneRaw }}">Pozovi salon</a>
        <a class="st-btn st-btn-ghost" href="https://instagram.com/{{ site.instagram }}" target="_blank" rel="noopener">@{{ site.instagram }}</a>
      </div>
    </div>
    {{ shared.footer(site, year) }}
  </section>

  {{ shared.ctaBar(site) }}
</div>

{{ shared.baseJs() }}
{% endblock %}
