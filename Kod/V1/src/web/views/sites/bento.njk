{% extends "marketing.njk" %}
{% import "sites/_shared.njk" as shared %}
{% block title %}{{ site.name }} — zakazivanje i cenovnik{% endblock %}

{% block head %}
{{ shared.themeStyle(theme, demo) }}
<style>
  /* ====================================================================
     Izgled "Bento": ceo sajt kao kartice u bento mreži — app osećaj,
     bez dugog skrola. Hover podiže kartice.
     ==================================================================== */
  .bn-wrap { max-width: 80rem; margin-inline: auto; padding: calc(var(--demo-offset, 0px) + 1.25rem) 1rem 2rem; }

  .bn-top { display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding: 0.35rem 0.35rem 1.1rem; }
  .bn-logo {
    display: inline-flex; height: 2.4rem; width: 2.4rem; align-items: center; justify-content: center;
    border-radius: 9999px; border: 1px solid color-mix(in srgb, var(--brand) 55%, transparent);
    color: var(--brand); font-size: 16px;
  }

  .bn-grid { display: grid; gap: 0.9rem; grid-template-columns: 1fr; }
  .bn-card {
    position: relative; overflow: hidden; background: var(--s-surface);
    border: 1px solid var(--s-line); border-radius: var(--s-radius); padding: 1.6rem;
    transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1), border-color 0.4s, box-shadow 0.4s;
  }
  .bn-card:hover {
    transform: translateY(-5px); border-color: color-mix(in srgb, var(--brand) 40%, transparent);
    box-shadow: 0 24px 60px -28px rgba(0, 0, 0, 0.5);
  }

  @media (min-width: 900px) {
    .bn-grid {
      grid-template-columns: repeat(4, 1fr);
      grid-template-areas:
        "hero hero cen cen"
        "hero hero cen cen"
        "g1   g2   cen cen"
        "tim  tim  sati kon";
    }
    .bn-hero { grid-area: hero; }
    .bn-cen { grid-area: cen; }
    .bn-g1 { grid-area: g1; }
    .bn-g2 { grid-area: g2; }
    .bn-tim { grid-area: tim; }
    .bn-sati { grid-area: sati; }
    .bn-kon { grid-area: kon; }
  }

  /* hero kartica — aurora dah unutar kartice */
  .bn-hero { padding: clamp(1.6rem, 4vw, 2.75rem); display: flex; flex-direction: column; justify-content: flex-end; min-height: 24rem; }
  .bn-hero-glow { position: absolute; inset: 0; pointer-events: none; }
  .bn-hero-glow span { position: absolute; border-radius: 9999px; filter: blur(70px); }
  .bn-hero-glow span:nth-child(1) { width: 26rem; height: 26rem; right: -8rem; top: -10rem; background: radial-gradient(circle, var(--s-aurora1), transparent 65%); }
  .bn-hero-glow span:nth-child(2) { width: 20rem; height: 20rem; left: -6rem; bottom: -8rem; background: radial-gradient(circle, var(--s-aurora2), transparent 65%); }
  .bn-h1 { font-size: clamp(2.2rem, 5vw, 3.6rem); line-height: 1.05; }
  .bn-h1 em { font-style: italic; color: var(--brand); }

  .bn-card-kicker { font-size: 10px; letter-spacing: 0.3em; text-transform: uppercase; color: var(--brand); font-weight: 600; }

  /* cenovnik kartica */
  .bn-price-row { display: flex; align-items: baseline; gap: 0.7rem; padding: 0.8rem 0; border-bottom: 1px solid var(--s-line); }
  .bn-price-row:last-child { border-bottom: 0; }
  .bn-price-dots { flex: 1; border-bottom: 1px dotted color-mix(in srgb, var(--s-ink) 22%, transparent); transform: translateY(-4px); }
  .bn-price-val { font-variant-numeric: tabular-nums; font-size: 14px; }
  .bn-price-row:hover .bn-price-val { color: var(--brand); }

  /* galerija kartice — art preko cele kartice */
  .bn-gal { padding: 0; min-height: 13rem; }
  .bn-gal .st-tile-art { inset: -10%; }

  /* radno vreme */
  .bn-hours-row { display: flex; justify-content: space-between; gap: 0.6rem; padding: 0.45rem 0; font-size: 13px; font-variant-numeric: tabular-nums; }
  .bn-hours-row.today { color: var(--brand); font-weight: 600; }

  /* tim kartica */
  .bn-staff { display: flex; flex-wrap: wrap; gap: 1.4rem 2rem; }
  .bn-staff-item { display: flex; align-items: center; gap: 0.9rem; }

  .bn-phone { font-variant-numeric: tabular-nums; color: var(--s-ink); text-decoration: none; transition: color 0.3s; font-size: clamp(1.3rem, 2vw, 1.55rem); }
  .bn-phone:hover { color: var(--brand); }
</style>
{% endblock %}

{% block content %}
<div class="site st-grain">

  {% if demo %}{{ shared.demoBar(layoutList, themeList, layout, theme) }}{% endif %}

  <div class="bn-wrap">

    <!-- traka iznad mreže -->
    <div class="bn-top">
      <a href="/sajt-demo" style="display:flex;align-items:center;gap:.7rem;text-decoration:none;color:inherit">
        <span class="bn-logo st-serif">{{ site.name[0] }}</span>
        <span class="st-serif" style="font-size:17px">{{ site.name }}</span>
      </a>
      <a class="st-btn st-btn-gold st-btn-shine" style="height:2.75rem;padding-inline:1.2rem;font-size:13px" href="tel:{{ site.phoneRaw }}">Zakaži termin</a>
    </div>

    <div class="bn-grid">

      <!-- Hero kartica -->
      <header class="bn-card bn-hero" data-hero>
        <div class="bn-hero-glow" aria-hidden="true"><span></span><span></span></div>
        <div style="position:relative">
          <p class="st-kicker">{{ site.tagline }}</p>
          <h1 class="st-serif bn-h1" style="margin-top:1rem">Kosa koja govori <em>umesto tebe.</em></h1>
          <p style="margin-top:1.2rem;max-width:28rem;color:var(--s-muted);font-size:15px;line-height:1.65">{{ site.about }}</p>
          <div style="margin-top:1.8rem;display:flex;flex-wrap:wrap;gap:.8rem">
            <a class="st-btn st-btn-gold st-btn-shine" href="tel:{{ site.phoneRaw }}">Zakaži termin</a>
            <a class="st-btn st-btn-ghost" href="https://instagram.com/{{ site.instagram }}" target="_blank" rel="noopener">@{{ site.instagram }}</a>
          </div>
          <div style="margin-top:2rem;display:flex;flex-wrap:wrap;gap:1.8rem">
            {% for f in site.facts %}
            <div>
              <p class="st-serif" style="font-size:1.4rem;color:var(--brand)">{{ f.n }}</p>
              <p style="font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:var(--s-muted)">{{ f.label }}</p>
            </div>
            {% endfor %}
          </div>
        </div>
      </header>

      <!-- Cenovnik kartica -->
      <section class="bn-card bn-cen rev">
        <p class="bn-card-kicker">Cenovnik</p>
        <h2 class="st-serif" style="margin-top:.7rem;font-size:1.5rem">Jasne cene. Bez zvezdica.</h2>
        <div style="margin-top:1rem">
          {% for s in services %}
          <div class="bn-price-row">
            <div>
              <p style="font-size:15px">{{ s.name }}</p>
              <p style="font-size:11px;color:var(--s-muted)">{{ s.durationMin }} min</p>
            </div>
            <span class="bn-price-dots" aria-hidden="true"></span>
            <span class="bn-price-val">{{ s.price }}</span>
          </div>
          {% endfor %}
        </div>
        <p style="margin-top:1rem;font-size:12px;color:var(--s-muted)">O nama: {{ site.aboutLong }}</p>
      </section>

      <!-- Galerija kartice -->
      {% for g in gallery.slice(0, 2) %}
      <figure class="bn-card bn-gal st-tile rev bn-g{{ loop.index }}" style="--d:{{ loop.index0 * 0.08 }}s;border-radius:var(--s-radius)">
        <div class="st-tile-art" style="background:{{ g.art }}"></div>
        <span class="st-tile-label">{{ g.label }}</span>
      </figure>
      {% endfor %}

      <!-- Tim kartica -->
      <section class="bn-card bn-tim rev">
        <p class="bn-card-kicker">Tim</p>
        <div class="bn-staff" style="margin-top:1.1rem">
          {% for m in staff %}
          <div class="bn-staff-item">
            <span class="st-avatar st-serif" style="background:{{ m.color }};height:2.9rem;width:2.9rem;font-size:15px">{{ m.initials }}</span>
            <span>
              <p style="font-size:15px;font-weight:600">{{ m.name }}</p>
              <p style="font-size:12px;color:var(--s-muted)">{{ m.role }}</p>
            </span>
          </div>
          {% endfor %}
        </div>
      </section>

      <!-- Radno vreme kartica -->
      <section class="bn-card bn-sati rev" style="--d:.08s">
        <p class="bn-card-kicker">Radno vreme</p>
        <div style="margin-top:.9rem">
          {% for h in hours %}
          <div class="bn-hours-row {% if h.today %}today{% endif %}">
            <span>{{ h.label.slice(0, 3) }}</span>
            <span style="{% if not h.open %}color:var(--s-muted){% endif %}">{{ h.time }}</span>
          </div>
          {% endfor %}
        </div>
      </section>

      <!-- Kontakt kartica -->
      <section class="bn-card bn-kon rev" style="--d:.16s;display:flex;flex-direction:column">
        <p class="bn-card-kicker">Kontakt</p>
        <a class="st-serif bn-phone" style="margin-top:.9rem" href="tel:{{ site.phoneRaw }}">{{ site.phone }}</a>
        <p style="margin-top:.7rem;font-size:13px;color:var(--s-muted);line-height:1.55">
          <a href="https://www.google.com/maps/search/{{ site.address | urlencode }}" target="_blank" rel="noopener" style="color:inherit">{{ site.address }}</a>
        </p>
        <a class="st-btn st-btn-gold st-btn-shine" style="margin-top:auto;padding-top:0;width:100%" href="tel:{{ site.phoneRaw }}">Pozovi</a>
      </section>

    </div>
  </div>

  {{ shared.footer(site, year) }}
  {{ shared.ctaBar(site) }}
</div>

{{ shared.baseJs() }}
{% endblock %}
