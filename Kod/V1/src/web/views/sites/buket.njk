{% extends "marketing.njk" %}
{% import "sites/_shared.njk" as shared %}
{% block title %}{{ site.name }} — zakazivanje i cenovnik{% endblock %}

{# Cvetić od 5 latica — boja preko currentColor, sredina "izbušena" surface bojom. #}
{% macro flower(cls) %}
<svg class="bu-flower {{ cls }}" viewBox="0 0 24 24" aria-hidden="true"><g fill="currentColor"><ellipse cx="12" cy="6" rx="3" ry="4.6"/><ellipse cx="12" cy="6" rx="3" ry="4.6" transform="rotate(72 12 12)"/><ellipse cx="12" cy="6" rx="3" ry="4.6" transform="rotate(144 12 12)"/><ellipse cx="12" cy="6" rx="3" ry="4.6" transform="rotate(216 12 12)"/><ellipse cx="12" cy="6" rx="3" ry="4.6" transform="rotate(288 12 12)"/></g><circle cx="12" cy="12" r="2" fill="var(--s-bg)"/></svg>
{% endmacro %}

{# Čipkasta (skalop) ivica: polukrugovi surface boje na --s-bg podlozi.
   Bez flipa polukrugovi "vire" nagore (ulaz u surface pojas), sa flipom
   nadole (izlaz) — kao talas u "svila", samo cvetnije. #}
{% macro scallop(flip) %}
<div class="bu-scallop{% if flip %} bu-flip{% endif %}" aria-hidden="true"></div>
{% endmacro %}

{% block head %}
{{ shared.themeStyle(theme, demo) }}
<style>
  /* ====================================================================
     Izgled "Buket": cvetno i razigrano — čipkaste (skalop) ivice između
     sekcija, cvetići koji plutaju u hero-u, galerija u ovalnim ramovima
     sa tačkastim vencem, tim sa cvetnim prstenom. Za salone koji žele
     sladak, devojački ton — ništa strogo, sve meko.
     ==================================================================== */
  .bu-wrap { max-width: 64rem; margin-inline: auto; padding-inline: 1.25rem; }
  .bu-section { padding-block: 4.5rem; }
  .bu-surface { background: var(--s-surface); }
  .bu-h2 { font-size: clamp(1.9rem, 4.5vw, 2.8rem); line-height: 1.12; }
  .bu-h2 em, .bu-h1 em { font-style: italic; color: var(--brand); }

  .bu-scallop {
    height: 1rem; margin-top: -1px;
    background: radial-gradient(circle at 50% 100%, var(--s-surface) 62%, transparent 64%);
    background-size: 2rem 2rem; background-position: 50% 100%; background-repeat: repeat-x;
  }
  .bu-flip { transform: scaleY(-1); }

  .bu-flower { width: 1.1rem; height: 1.1rem; color: var(--brand); }

  /* --- navigacija --------------------------------------------------------- */
  .bu-nav {
    position: fixed; inset-inline: 0; top: var(--demo-offset, 0); z-index: 50;
    border-bottom: 1px solid transparent;
    transition: background 0.4s ease, border-color 0.4s ease, backdrop-filter 0.4s ease;
  }
  .bu-nav.scrolled { background: color-mix(in srgb, var(--s-bg) 84%, transparent); backdrop-filter: blur(12px); border-color: var(--s-line); }

  /* --- hero: cvetići plutaju ---------------------------------------------- */
  .bu-hero {
    position: relative; min-height: 88svh; display: flex; flex-direction: column;
    align-items: center; justify-content: center; text-align: center;
    padding: calc(var(--demo-offset, 0px) + 6rem) 1.25rem 5rem;
    background:
      radial-gradient(100% 70% at 50% 0%, color-mix(in srgb, var(--brand) 8%, var(--s-bg)), transparent 70%),
      radial-gradient(55% 40% at 15% 80%, var(--s-aurora2), transparent 70%),
      radial-gradient(50% 38% at 88% 70%, var(--s-aurora3), transparent 70%);
  }
  .bu-h1 { font-size: clamp(2.6rem, 8vw, 5rem); line-height: 1.08; max-width: 18ch; }
  .bu-float { position: absolute; animation: bu-float 8s ease-in-out infinite alternate; animation-delay: var(--d, 0s); }
  @keyframes bu-float { from { transform: translateY(-8px) rotate(-8deg); } to { transform: translateY(10px) rotate(10deg); } }
  .bu-bloom { opacity: 0; transform: translateY(16px) scale(0.98); animation: bu-bloom 1.2s cubic-bezier(0.22, 1, 0.36, 1) forwards; animation-delay: var(--d, 0s); }
  @keyframes bu-bloom { to { opacity: 1; transform: none; } }
  .bu-kicker-row { display: inline-flex; align-items: center; gap: 0.6rem; }

  /* --- cenovnik: kartice sa cvetićem uz cenu -------------------------------- */
  .bu-cards { display: grid; gap: 1rem; grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr)); }
  .bu-card {
    background: var(--s-bg); border-radius: calc(var(--s-radius) * 1.1); padding: 1.7rem 1.5rem;
    border: 1px dashed color-mix(in srgb, var(--brand) 30%, transparent);
    transition: transform 0.45s cubic-bezier(0.22, 1, 0.36, 1), border-color 0.45s, box-shadow 0.45s;
  }
  .bu-card:hover { transform: translateY(-5px); border-color: color-mix(in srgb, var(--brand) 55%, transparent); box-shadow: 0 24px 55px -35px color-mix(in srgb, var(--brand) 40%, rgba(0, 0, 0, 0.3)); }
  .bu-card-val { display: inline-flex; align-items: center; gap: 0.5rem; font-family: var(--s-display); font-size: 1.3rem; color: var(--brand); font-variant-numeric: tabular-nums; }

  /* --- galerija: ovali sa tačkastim vencem ---------------------------------- */
  .bu-gal { display: grid; gap: 2.2rem 1.4rem; grid-template-columns: repeat(2, 1fr); }
  @media (min-width: 768px) { .bu-gal { grid-template-columns: repeat(3, 1fr); gap: 2.6rem 1.8rem; } }
  .bu-gal figure { margin: 0; text-align: center; }
  .bu-oval {
    position: relative; overflow: hidden; aspect-ratio: 4 / 5; border-radius: 50%;
    outline: 1px dashed color-mix(in srgb, var(--brand) 40%, transparent); outline-offset: 6px;
    box-shadow: 0 24px 55px -35px rgba(0, 0, 0, 0.4);
    transition: transform 0.55s cubic-bezier(0.22, 1, 0.36, 1), outline-offset 0.55s, outline-color 0.55s;
  }
  .bu-gal figure:hover .bu-oval { transform: scale(1.03); outline-offset: 10px; outline-color: color-mix(in srgb, var(--brand) 65%, transparent); }
  .bu-oval > div { position: absolute; inset: -10%; }
  .bu-gal figcaption { margin-top: 1rem; display: inline-flex; align-items: center; gap: 0.5rem; font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--s-muted); }
  .bu-gal figcaption .bu-flower { width: 0.85rem; height: 0.85rem; opacity: 0.75; }

  /* --- tim: cvetni prsten oko avatara --------------------------------------- */
  .bu-team { display: flex; flex-wrap: wrap; justify-content: center; gap: 2.4rem 3rem; }
  .bu-member { text-align: center; }
  .bu-member .st-avatar {
    height: 5.6rem; width: 5.6rem; font-size: 24px; margin-inline: auto;
    outline: 1px dashed color-mix(in srgb, var(--brand) 45%, transparent); outline-offset: 7px;
    transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1), outline-offset 0.6s;
  }
  .bu-member:hover .st-avatar { transform: rotate(6deg); outline-offset: 11px; }

  /* --- radno vreme ----------------------------------------------------------- */
  .bu-hours { max-width: 24rem; margin-inline: auto; }
  .bu-hours-row {
    display: flex; align-items: center; justify-content: space-between; gap: 1rem;
    padding: 0.65rem 1.1rem; border-radius: 9999px; font-size: 14px; font-variant-numeric: tabular-nums;
  }
  .bu-hours-row.today { background: color-mix(in srgb, var(--brand) 10%, transparent); color: var(--brand); font-weight: 600; }
  .bu-hours-row .bu-flower { width: 0.85rem; height: 0.85rem; margin-right: 0.45rem; vertical-align: -1px; }

  .bu-phone { font-family: var(--s-display); font-weight: var(--s-display-weight); font-size: clamp(2rem, 6vw, 3.2rem); color: var(--s-ink); text-decoration: none; transition: color 0.3s; font-variant-numeric: tabular-nums; }
  .bu-phone:hover { color: var(--brand); }

  @media (prefers-reduced-motion: reduce) {
    .bu-bloom { opacity: 1 !important; transform: none !important; }
  }
</style>
{% endblock %}

{% block content %}
<div class="site st-grain">

  {% if demo %}{{ shared.demoBar(layoutList, themeList, layout, theme) }}{% endif %}

  <!-- Navigacija -->
  <nav class="bu-nav" data-nav>
    <div class="bu-wrap" style="display:flex;align-items:center;justify-content:space-between;gap:1rem;height:4.25rem">
      <a href="#vrh" style="display:inline-flex;align-items:center;gap:.55rem;text-decoration:none;color:inherit">
        {{ flower("") }}<span class="st-serif" style="font-size:17px">{{ site.name }}</span>
      </a>
      <a class="st-btn st-btn-gold st-btn-shine" style="height:2.75rem;padding-inline:1.2rem;font-size:13px" href="tel:{{ site.phoneRaw }}">Zakaži</a>
    </div>
  </nav>

  <!-- Hero: cvetići plutaju -->
  <header class="bu-hero" id="vrh" data-hero>
    <span class="bu-float" style="top:16%;left:12%;--d:0s;opacity:.5">{{ flower("") }}</span>
    <span class="bu-float" style="top:24%;right:14%;--d:1.2s;opacity:.7;scale:1.6">{{ flower("") }}</span>
    <span class="bu-float" style="bottom:22%;left:20%;--d:2s;opacity:.6;scale:1.3">{{ flower("") }}</span>
    <span class="bu-float" style="bottom:16%;right:22%;--d:.6s;opacity:.4">{{ flower("") }}</span>
    <p class="bu-kicker-row st-kicker bu-bloom">{{ flower("") }}{{ site.tagline }}{{ flower("") }}</p>
    <h1 class="st-serif bu-h1 bu-bloom" style="--d:.12s;margin-top:1.4rem">Uđi — i pusti dan da <em>procveta.</em></h1>
    <p class="bu-bloom" style="--d:.26s;margin-top:1.5rem;max-width:30rem;color:var(--s-muted);font-size:16px;line-height:1.7">{{ site.about }}</p>
    <div class="bu-bloom" style="--d:.4s;margin-top:2.3rem;display:flex;flex-wrap:wrap;gap:.9rem;justify-content:center">
      <a class="st-btn st-btn-gold st-btn-shine" href="tel:{{ site.phoneRaw }}">Zakaži termin</a>
      <a class="st-btn st-btn-ghost" href="#cenovnik">Pogledaj cenovnik</a>
    </div>
  </header>

  <!-- O nama (surface, čipkasti ulaz/izlaz) -->
  {{ scallop(false) }}
  <section class="bu-surface bu-section" id="onama">
    <div class="bu-wrap" style="text-align:center">
      <p class="st-kicker rev">O nama</p>
      <h2 class="st-serif bu-h2 rev" style="margin-top:1rem;margin-inline:auto;max-width:24ch">Zanat star koliko i lepota. <em>Pristup — nov.</em></h2>
      <p class="rev" style="margin-top:1.4rem;margin-inline:auto;max-width:36rem;color:var(--s-muted);font-size:16px;line-height:1.75">{{ site.aboutLong }}</p>
      <div style="margin-top:2.4rem;display:flex;justify-content:center;flex-wrap:wrap;gap:2.6rem">
        {% for f in site.facts %}
        <div class="rev" style="--d:{{ loop.index0 * 0.12 }}s">
          <p class="st-serif" style="font-size:2rem;color:var(--brand)">{{ f.n }}</p>
          <p style="font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:var(--s-muted);margin-top:.2rem">{{ f.label }}</p>
        </div>
        {% endfor %}
      </div>
    </div>
  </section>
  {{ scallop(true) }}

  <!-- Cenovnik -->
  <section class="bu-section" id="cenovnik">
    <div class="bu-wrap">
      <div style="text-align:center">
        <p class="st-kicker rev">Cenovnik</p>
        <h2 class="st-serif bu-h2 rev" style="margin-top:1rem">Male cene, <em>velika nega.</em></h2>
      </div>
      <div class="bu-cards" style="margin-top:2.6rem">
        {% for s in services %}
        <div class="bu-card rev" style="--d:{{ loop.index0 * 0.07 }}s">
          <p style="font-size:16px;font-weight:600">{{ s.name }}</p>
          <p style="margin-top:.3rem;font-size:12px;color:var(--s-muted)">{{ s.durationMin }} min</p>
          <p class="bu-card-val" style="margin-top:1.1rem">{{ flower("") }}{{ s.price }}</p>
        </div>
        {% endfor %}
      </div>
      <p class="rev" style="margin-top:1.8rem;text-align:center;font-size:13px;color:var(--s-muted)">Cene su informativne — za duge/gušće kose javi nam se porukom pre termina.</p>
    </div>
  </section>

  <!-- Galerija (surface) -->
  {{ scallop(false) }}
  <section class="bu-surface bu-section" id="galerija">
    <div class="bu-wrap">
      <div style="text-align:center">
        <p class="st-kicker rev">Galerija</p>
        <h2 class="st-serif bu-h2 rev" style="margin-top:1rem">Buket <em>naših radova.</em></h2>
      </div>
      <div class="bu-gal" style="margin-top:2.8rem">
        {% for g in gallery %}
        <figure class="rev" style="--d:{{ loop.index0 * 0.08 }}s">
          <div class="bu-oval"><div style="background:{{ g.art }}"></div></div>
          <figcaption>{{ flower("") }}{{ g.label }}</figcaption>
        </figure>
        {% endfor %}
      </div>
    </div>
  </section>
  {{ scallop(true) }}

  <!-- Tim -->
  <section class="bu-section" id="tim">
    <div class="bu-wrap" style="text-align:center">
      <p class="st-kicker rev">Tim</p>
      <h2 class="st-serif bu-h2 rev" style="margin-top:1rem">Ruke od poverenja.</h2>
      <div class="bu-team" style="margin-top:2.8rem">
        {% for m in staff %}
        <div class="bu-member rev" style="--d:{{ loop.index0 * 0.1 }}s">
          <span class="st-avatar st-serif" style="background:{{ m.color }}">{{ m.initials }}</span>
          <p style="margin-top:1.1rem;font-size:16px;font-weight:600">{{ m.name }}</p>
          <p style="margin-top:.15rem;font-size:13px;color:var(--s-muted)">{{ m.role }}</p>
        </div>
        {% endfor %}
      </div>
    </div>
  </section>

  <!-- Radno vreme + kontakt (surface) -->
  {{ scallop(false) }}
  <section class="bu-surface bu-section" id="kontakt" style="padding-bottom:3rem">
    <div class="bu-wrap" style="text-align:center">
      <p class="st-kicker rev">Radno vreme</p>
      <div class="bu-hours rev" style="margin-top:1.6rem">
        {% for h in hours %}
        <div class="bu-hours-row {% if h.today %}today{% endif %}">
          <span>{% if h.today %}{{ flower("") }}{% endif %}{{ h.label }}</span>
          <span style="{% if not h.open %}color:var(--s-muted){% endif %}">{{ h.time }}</span>
        </div>
        {% endfor %}
      </div>

      <p class="st-kicker rev" style="margin-top:3.4rem">Kontakt</p>
      <h2 class="st-serif bu-h2 rev" style="margin-top:1rem">Vidimo se <em>u salonu.</em></h2>
      <a class="bu-phone rev" style="display:inline-block;margin-top:1.2rem" href="tel:{{ site.phoneRaw }}">{{ site.phone }}</a>
      <p class="rev" style="margin-top:.8rem;color:var(--s-muted);font-size:14px">
        <a href="https://www.google.com/maps/search/{{ site.address | urlencode }}" target="_blank" rel="noopener" style="color:inherit">{{ site.address }}</a>
      </p>
      <div class="rev" style="margin-top:1.8rem;display:flex;flex-wrap:wrap;gap:.9rem;justify-content:center">
        <a class="st-btn st-btn-gold st-btn-shine" href="tel:{{ site.phoneRaw }}">Pozovi salon</a>
        <a class="st-btn st-btn-ghost" href="https://instagram.com/{{ site.instagram }}" target="_blank" rel="noopener">@{{ site.instagram }}</a>
      </div>
    </div>
    {{ shared.footer(site, year) }}
  </section>

  {{ shared.ctaBar(site) }}
</div>

{{ shared.baseJs() }}
{% endblock %}
