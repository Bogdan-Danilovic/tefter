{% extends "marketing.njk" %}
{% import "sites/_shared.njk" as shared %}
{% block title %}{{ site.name }} — zakazivanje i cenovnik{% endblock %}

{# Talasasti prelaz između sekcija: svg stoji na --s-bg, a path boje --s-surface
   "izranja" odozdo (normalno) ili odozgo (sv-flip) — ništa nije pravougaono. #}
{% macro wave(flip) %}
<svg class="sv-wave{% if flip %} sv-flip{% endif %}" viewBox="0 0 1440 88" preserveAspectRatio="none" aria-hidden="true"><path fill="currentColor" d="M0,46 C240,86 480,6 720,38 C960,70 1200,18 1440,50 L1440,88 L0,88 Z"/></svg>
{% endmacro %}

{% block head %}
{{ shared.themeStyle(theme, demo) }}
<style>
  /* ====================================================================
     Izgled "Svila": organski i prozračan — mekan gradijent umesto oštrih
     aurora, talasasti prelazi između sekcija, galerija kao "latice",
     cenovnik kao mekane kartice. Projektovan za beauty/hair salone.
     ==================================================================== */
  .sv-wrap { max-width: 64rem; margin-inline: auto; padding-inline: 1.25rem; }

  .sv-wave { display: block; width: 100%; height: clamp(2.5rem, 7vw, 5rem); color: var(--s-surface); margin-block: -1px; }
  .sv-flip { transform: scaleY(-1); }
  .sv-on-surface { background: var(--s-surface); }

  /* --- plutajuća pilula navigacija -------------------------------------- */
  .sv-nav {
    position: fixed; inset-inline: max(0.9rem, env(safe-area-inset-left)); top: calc(var(--demo-offset, 0px) + 0.8rem); z-index: 50;
    max-width: 64rem; margin-inline: auto; border-radius: 9999px;
    display: flex; align-items: center; justify-content: space-between; gap: 1rem;
    padding: 0.45rem 0.55rem 0.45rem 1.1rem; border: 1px solid transparent;
    transition: background 0.4s ease, border-color 0.4s ease, box-shadow 0.4s ease, backdrop-filter 0.4s ease;
  }
  .sv-nav.scrolled {
    background: color-mix(in srgb, var(--s-surface) 82%, transparent); backdrop-filter: blur(14px);
    border-color: var(--s-line); box-shadow: 0 18px 45px -28px rgba(0, 0, 0, 0.35);
  }
  .sv-nav-links { display: none; gap: 1.5rem; }
  @media (min-width: 768px) { .sv-nav-links { display: flex; } }
  .sv-nav-link { font-size: 13px; color: var(--s-muted); text-decoration: none; transition: color 0.25s; }
  .sv-nav-link:hover { color: var(--brand); }

  /* --- hero: puno vazduha, mekan gradijent ------------------------------- */
  .sv-hero {
    min-height: 92svh; display: flex; flex-direction: column; align-items: center; justify-content: center;
    text-align: center; position: relative; padding: calc(var(--demo-offset, 0px) + 6rem) 1.25rem 5rem;
    background:
      radial-gradient(110% 75% at 50% 0%, color-mix(in srgb, var(--brand) 9%, var(--s-bg)), transparent 70%),
      radial-gradient(60% 45% at 18% 85%, var(--s-aurora2), transparent 70%),
      radial-gradient(55% 40% at 85% 75%, var(--s-aurora3), transparent 70%);
  }
  .sv-h1 { font-size: clamp(2.7rem, 8vw, 5.2rem); line-height: 1.08; font-weight: 400; max-width: 18ch; }
  .sv-h1 em { font-style: italic; color: var(--brand); }
  .sv-breath { opacity: 0; transform: translateY(16px); animation: sv-breath 1.3s cubic-bezier(0.22, 1, 0.36, 1) forwards; animation-delay: var(--d, 0s); }
  @keyframes sv-breath { to { opacity: 1; transform: none; } }
  .sv-btn-soft { box-shadow: 0 18px 45px -18px color-mix(in srgb, var(--brand) 60%, transparent); }

  .sv-h2 { font-size: clamp(1.9rem, 4.5vw, 2.9rem); line-height: 1.12; font-weight: 400; }
  .sv-h2 em { font-style: italic; color: var(--brand); }
  .sv-section { padding-block: 4.5rem; }

  /* --- cenovnik: mekane kartice, puno paddinga --------------------------- */
  .sv-price-grid { display: grid; gap: 1rem; grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr)); }
  .sv-price-card {
    background: var(--s-surface); border-radius: calc(var(--s-radius) * 1.15);
    padding: 1.9rem 1.7rem; box-shadow: 0 22px 55px -35px rgba(0, 0, 0, 0.35);
    transition: transform 0.45s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.45s;
  }
  .sv-price-card:hover { transform: translateY(-5px); box-shadow: 0 30px 65px -32px color-mix(in srgb, var(--brand) 35%, rgba(0, 0, 0, 0.3)); }
  .sv-price-card .sv-val { font-size: 1.35rem; color: var(--brand); font-variant-numeric: tabular-nums; }

  /* --- galerija: latice --------------------------------------------------- */
  .sv-petals { display: grid; gap: 1.6rem 1.2rem; grid-template-columns: repeat(2, 1fr); }
  @media (min-width: 768px) { .sv-petals { grid-template-columns: repeat(3, 1fr); gap: 2.2rem 1.6rem; } }
  .sv-petal { margin: 0; text-align: center; }
  .sv-petal-art {
    position: relative; overflow: hidden; aspect-ratio: 1 / 1;
    transition: border-radius 0.6s cubic-bezier(0.22, 1, 0.36, 1), transform 0.6s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.6s;
    box-shadow: 0 24px 55px -35px rgba(0, 0, 0, 0.4);
  }
  .sv-petal:nth-child(3n + 1) .sv-petal-art { border-radius: 60% 40% 55% 45% / 45% 55% 40% 60%; transform: rotate(-3deg); }
  .sv-petal:nth-child(3n + 2) .sv-petal-art { border-radius: 42% 58% 48% 52% / 55% 42% 58% 45%; transform: rotate(2deg); }
  .sv-petal:nth-child(3n) .sv-petal-art { border-radius: 55% 45% 60% 40% / 42% 58% 45% 55%; transform: rotate(-1.5deg); }
  .sv-petal:hover .sv-petal-art { border-radius: 50%; transform: rotate(0) scale(1.03); }
  .sv-petal-art > div { position: absolute; inset: -10%; }
  .sv-petal figcaption { margin-top: 0.9rem; font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--s-muted); }

  /* --- tim: velike okrugle "fotografije" ---------------------------------- */
  .sv-team { display: flex; flex-wrap: wrap; justify-content: center; gap: 2.4rem 3rem; }
  .sv-member { text-align: center; }
  .sv-member .st-avatar {
    height: 6rem; width: 6rem; font-size: 26px; margin-inline: auto;
    box-shadow: 0 18px 40px -22px rgba(0, 0, 0, 0.45), 0 0 0 6px color-mix(in srgb, var(--brand) 14%, transparent);
    transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .sv-member:hover .st-avatar { transform: translateY(-6px) rotate(3deg); }

  /* --- radno vreme + kontakt ---------------------------------------------- */
  .sv-hours { max-width: 24rem; margin-inline: auto; }
  .sv-hours-row {
    display: flex; justify-content: space-between; gap: 1rem; padding: 0.7rem 1.1rem;
    border-radius: 9999px; font-size: 14px; font-variant-numeric: tabular-nums;
  }
  .sv-hours-row.today { background: color-mix(in srgb, var(--brand) 11%, transparent); color: var(--brand); font-weight: 600; }
  .sv-phone { font-family: var(--s-display); font-size: clamp(2rem, 6vw, 3.2rem); font-weight: 400; letter-spacing: var(--s-display-tracking); color: var(--s-ink); text-decoration: none; transition: color 0.3s; font-variant-numeric: tabular-nums; }
  .sv-phone:hover { color: var(--brand); }

  @media (prefers-reduced-motion: reduce) {
    .sv-breath { opacity: 1 !important; transform: none !important; }
  }
</style>
{% endblock %}

{% block content %}
<div class="site st-grain">

  {% if demo %}{{ shared.demoBar(layoutList, themeList, layout, theme) }}{% endif %}

  <!-- Plutajuća navigacija -->
  <nav class="sv-nav" data-nav>
    <a href="#vrh" style="display:flex;align-items:center;gap:.6rem;text-decoration:none;color:inherit">
      <span class="st-serif" style="font-size:17px">{{ site.name }}</span>
    </a>
    <div class="sv-nav-links">
      <a class="sv-nav-link" href="#onama">O nama</a>
      <a class="sv-nav-link" href="#cenovnik">Cenovnik</a>
      <a class="sv-nav-link" href="#galerija">Galerija</a>
      <a class="sv-nav-link" href="#tim">Tim</a>
      <a class="sv-nav-link" href="#kontakt">Kontakt</a>
    </div>
    <a class="st-btn st-btn-gold" style="height:2.75rem;padding-inline:1.2rem;font-size:13px" href="tel:{{ site.phoneRaw }}">Zakaži</a>
  </nav>

  <!-- Hero -->
  <header class="sv-hero" id="vrh" data-hero>
    <p class="st-kicker sv-breath">{{ site.tagline }}</p>
    <h1 class="st-serif sv-h1 sv-breath" style="--d:.12s;margin-top:1.4rem">Nega koja se oseća <em>kao odmor.</em></h1>
    <p class="sv-breath" style="--d:.26s;margin-top:1.5rem;max-width:30rem;color:var(--s-muted);font-size:16px;line-height:1.7">{{ site.about }}</p>
    <div class="sv-breath" style="--d:.4s;margin-top:2.4rem;display:flex;flex-wrap:wrap;gap:.9rem;justify-content:center">
      <a class="st-btn st-btn-gold st-btn-shine sv-btn-soft" href="tel:{{ site.phoneRaw }}">Zakaži termin</a>
      <a class="st-btn st-btn-ghost" href="#cenovnik">Pogledaj cenovnik</a>
    </div>
  </header>

  <!-- O nama (surface, talasasti ulaz i izlaz) -->
  {{ wave(false) }}
  <section class="sv-on-surface sv-section" id="onama">
    <div class="sv-wrap" style="text-align:center">
      <p class="st-kicker rev">O nama</p>
      <h2 class="st-serif sv-h2 rev" style="margin-top:1rem;margin-inline:auto;max-width:22ch">Zanat star koliko i lepota. <em>Pristup — nov.</em></h2>
      <p class="rev" style="margin-top:1.4rem;margin-inline:auto;max-width:36rem;color:var(--s-muted);font-size:16px;line-height:1.75">{{ site.aboutLong }}</p>
      <div style="margin-top:2.4rem;display:flex;justify-content:center;flex-wrap:wrap;gap:2.6rem">
        {% for f in site.facts %}
        <div class="rev" style="--d:{{ loop.index0 * 0.12 }}s">
          <p class="st-serif" style="font-size:2rem;color:var(--brand)">{{ f.n }}</p>
          <p style="font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:var(--s-muted);margin-top:.2rem">{{ f.label }}</p>
        </div>
        {% endfor %}
      </div>
    </div>
  </section>
  {{ wave(true) }}

  <!-- Cenovnik: mekane kartice -->
  <section class="sv-section" id="cenovnik">
    <div class="sv-wrap">
      <div style="text-align:center">
        <p class="st-kicker rev">Cenovnik</p>
        <h2 class="st-serif sv-h2 rev" style="margin-top:1rem">Jasne cene. <em>Bez zvezdica.</em></h2>
      </div>
      <div class="sv-price-grid" style="margin-top:2.6rem">
        {% for s in services %}
        <div class="sv-price-card rev" style="--d:{{ loop.index0 * 0.07 }}s">
          <p style="font-size:16px;font-weight:600">{{ s.name }}</p>
          <p style="margin-top:.3rem;font-size:12px;color:var(--s-muted)">{{ s.durationMin }} min</p>
          <p class="st-serif sv-val" style="margin-top:1.1rem">{{ s.price }}</p>
        </div>
        {% endfor %}
      </div>
      <p class="rev" style="margin-top:1.8rem;text-align:center;font-size:13px;color:var(--s-muted)">Cene su informativne — za duge/gušće kose javi nam se porukom pre termina.</p>
    </div>
  </section>

  <!-- Galerija: latice (surface) -->
  {{ wave(false) }}
  <section class="sv-on-surface sv-section" id="galerija">
    <div class="sv-wrap">
      <div style="text-align:center">
        <p class="st-kicker rev">Galerija</p>
        <h2 class="st-serif sv-h2 rev" style="margin-top:1rem">Radovi koji pričaju.</h2>
      </div>
      <div class="sv-petals" style="margin-top:2.8rem">
        {% for g in gallery %}
        <figure class="sv-petal rev" style="--d:{{ loop.index0 * 0.08 }}s">
          <div class="sv-petal-art"><div style="background:{{ g.art }}"></div></div>
          <figcaption>{{ g.label }}</figcaption>
        </figure>
        {% endfor %}
      </div>
    </div>
  </section>
  {{ wave(true) }}

  <!-- Tim -->
  <section class="sv-section" id="tim">
    <div class="sv-wrap" style="text-align:center">
      <p class="st-kicker rev">Tim</p>
      <h2 class="st-serif sv-h2 rev" style="margin-top:1rem">Ruke od poverenja.</h2>
      <div class="sv-team" style="margin-top:2.6rem">
        {% for m in staff %}
        <div class="sv-member rev" style="--d:{{ loop.index0 * 0.1 }}s">
          <span class="st-avatar st-serif" style="background:{{ m.color }}">{{ m.initials }}</span>
          <p style="margin-top:1rem;font-size:16px;font-weight:600">{{ m.name }}</p>
          <p style="margin-top:.15rem;font-size:13px;color:var(--s-muted)">{{ m.role }}</p>
        </div>
        {% endfor %}
      </div>
    </div>
  </section>

  <!-- Radno vreme + kontakt (surface) -->
  {{ wave(false) }}
  <section class="sv-on-surface sv-section" id="kontakt" style="padding-bottom:3rem">
    <div class="sv-wrap" style="text-align:center">
      <p class="st-kicker rev">Radno vreme</p>
      <div class="sv-hours rev" style="margin-top:1.6rem">
        {% for h in hours %}
        <div class="sv-hours-row {% if h.today %}today{% endif %}">
          <span>{{ h.label }}</span>
          <span style="{% if not h.open %}color:var(--s-muted){% endif %}">{{ h.time }}</span>
        </div>
        {% endfor %}
      </div>

      <p class="st-kicker rev" style="margin-top:3.5rem">Kontakt</p>
      <h2 class="st-serif sv-h2 rev" style="margin-top:1rem">Vidimo se <em>u salonu.</em></h2>
      <a class="sv-phone rev" style="display:inline-block;margin-top:1.2rem" href="tel:{{ site.phoneRaw }}">{{ site.phone }}</a>
      <p class="rev" style="margin-top:.8rem;color:var(--s-muted);font-size:14px">
        <a href="https://www.google.com/maps/search/{{ site.address | urlencode }}" target="_blank" rel="noopener" style="color:inherit">{{ site.address }}</a>
      </p>
      <div class="rev" style="margin-top:1.8rem;display:flex;flex-wrap:wrap;gap:.9rem;justify-content:center">
        <a class="st-btn st-btn-gold st-btn-shine sv-btn-soft" href="tel:{{ site.phoneRaw }}">Pozovi salon</a>
        <a class="st-btn st-btn-ghost" href="https://instagram.com/{{ site.instagram }}" target="_blank" rel="noopener">@{{ site.instagram }}</a>
      </div>
    </div>
    {{ shared.footer(site, year) }}
  </section>

  {{ shared.ctaBar(site) }}
</div>

{{ shared.baseJs() }}
{% endblock %}
