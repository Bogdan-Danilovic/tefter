{% extends "marketing.njk" %}
{% import "sites/_shared.njk" as shared %}
{% block title %}{{ site.name }} — zakazivanje i cenovnik{% endblock %}

{% block head %}
{{ shared.themeStyle(theme, demo) }}
<style>
  /* ====================================================================
     Izgled "Ritual": spa jutro — sunce koje izlazi u hero-u, zamućene
     svetlosne kugle koje dišu, "ritual" u tri koraka na vertikalnoj
     liniji, cenovnik i radno vreme na plutajućim ostrvima sa ogromnim
     radiusom. Najprozračniji izgled — puno belina, sve sporo i meko.
     ==================================================================== */
  .ri-wrap { max-width: 62rem; margin-inline: auto; padding-inline: 1.25rem; }
  .ri-section { padding-block: 5rem; position: relative; }
  .ri-h2 { font-size: clamp(1.9rem, 4.5vw, 2.8rem); line-height: 1.12; }
  .ri-h2 em, .ri-h1 em { font-style: italic; color: var(--brand); }

  /* plutajuće ostrvo: velika surface kartica sa duplim radiusom */
  .ri-isle {
    background: var(--s-surface); border-radius: calc(var(--s-radius) * 1.9);
    padding: clamp(2rem, 5vw, 3.4rem); box-shadow: 0 34px 80px -50px rgba(0, 0, 0, 0.4);
  }

  /* zamućena svetlosna kugla koja diše */
  .ri-orb { position: absolute; border-radius: 9999px; filter: blur(46px); pointer-events: none; animation: ri-orb 9s ease-in-out infinite alternate; }
  @keyframes ri-orb { from { transform: translateY(-12px) scale(0.96); } to { transform: translateY(14px) scale(1.05); } }

  /* --- navigacija --------------------------------------------------------- */
  .ri-nav {
    position: fixed; inset-inline: 0; top: var(--demo-offset, 0); z-index: 50;
    border-bottom: 1px solid transparent;
    transition: background 0.4s ease, border-color 0.4s ease, backdrop-filter 0.4s ease;
  }
  .ri-nav.scrolled { background: color-mix(in srgb, var(--s-bg) 84%, transparent); backdrop-filter: blur(12px); border-color: var(--s-line); }

  /* --- hero: sunce izlazi -------------------------------------------------- */
  .ri-hero {
    position: relative; min-height: 92svh; display: flex; flex-direction: column;
    align-items: center; justify-content: center; text-align: center; overflow: clip;
    padding: calc(var(--demo-offset, 0px) + 6rem) 1.25rem 6rem;
    background:
      radial-gradient(70% 45% at 22% 10%, var(--s-aurora2), transparent 70%),
      radial-gradient(60% 40% at 82% 18%, var(--s-aurora3), transparent 70%);
  }
  .ri-sun {
    position: absolute; left: 50%; bottom: 8%; width: min(60vw, 24rem); aspect-ratio: 1;
    border-radius: 9999px; pointer-events: none;
    background: radial-gradient(circle at 50% 38%, color-mix(in srgb, var(--brand) 20%, var(--s-bg)), color-mix(in srgb, var(--brand) 7%, var(--s-bg)) 58%, transparent 72%);
    animation: ri-sunrise 2.4s cubic-bezier(0.22, 1, 0.36, 1) forwards; opacity: 0;
    transform: translateX(-50%) translateY(3.5rem);
  }
  @keyframes ri-sunrise { to { opacity: 1; transform: translateX(-50%) translateY(0); } }
  .ri-h1 { font-size: clamp(2.7rem, 8vw, 5.2rem); line-height: 1.08; max-width: 16ch; position: relative; }
  .ri-slow { opacity: 0; transform: translateY(18px); animation: ri-slow 1.5s cubic-bezier(0.22, 1, 0.36, 1) forwards; animation-delay: var(--d, 0s); position: relative; }
  @keyframes ri-slow { to { opacity: 1; transform: none; } }
  .ri-pulse { display: inline-block; width: 0.5rem; height: 0.5rem; border-radius: 9999px; background: var(--brand); margin-right: 0.5rem; vertical-align: 1px; animation: ri-pulse 4.5s ease-in-out infinite; }
  @keyframes ri-pulse { 0%, 100% { transform: scale(1); opacity: 0.7; } 50% { transform: scale(1.35); opacity: 1; } }

  /* --- ritual: tri koraka na liniji ----------------------------------------- */
  .ri-steps { max-width: 34rem; margin-inline: auto; text-align: left; position: relative; padding-left: 2.6rem; }
  .ri-steps::before { content: ""; position: absolute; left: 0.72rem; top: 0.5rem; bottom: 0.5rem; width: 1px; background: var(--s-line); }
  .ri-step { position: relative; padding-bottom: 2.2rem; }
  .ri-step:last-child { padding-bottom: 0; }
  .ri-step::before {
    content: ""; position: absolute; left: -2.6rem; top: 0.3rem; width: 1.45rem; height: 1.45rem;
    border-radius: 9999px; border: 1px solid color-mix(in srgb, var(--brand) 55%, transparent);
    background: color-mix(in srgb, var(--brand) 10%, var(--s-bg));
  }
  .ri-step-n { font-family: var(--s-display); font-size: 0.95rem; color: var(--brand); letter-spacing: 0.18em; }

  /* --- cenovnik: prostrani redovi ------------------------------------------- */
  .ri-menu { max-width: 38rem; margin-inline: auto; }
  .ri-row {
    display: flex; align-items: center; gap: 1rem; padding: 1rem 1.2rem;
    border-radius: 9999px; transition: background 0.35s;
  }
  .ri-row:hover { background: color-mix(in srgb, var(--brand) 7%, transparent); }
  .ri-row + .ri-row { margin-top: 0.15rem; }
  .ri-row-val { margin-left: auto; font-family: var(--s-display); font-size: 1.15rem; color: var(--brand); font-variant-numeric: tabular-nums; white-space: nowrap; }

  /* --- galerija: dve kolone u raskoraku -------------------------------------- */
  .ri-gal { display: grid; gap: 1.4rem; grid-template-columns: repeat(2, 1fr); }
  @media (min-width: 768px) { .ri-gal { gap: 2rem; } .ri-gal > *:nth-child(even) { transform: translateY(2.4rem); } }
  .ri-gal .st-tile { aspect-ratio: 4 / 5; border-radius: calc(var(--s-radius) * 1.6); box-shadow: 0 28px 60px -40px rgba(0, 0, 0, 0.45); }
  .ri-gal .st-tile-art { inset: -10%; }

  /* --- tim: pilule ------------------------------------------------------------ */
  .ri-team { display: flex; flex-wrap: wrap; justify-content: center; gap: 1rem; }
  .ri-chip {
    display: flex; align-items: center; gap: 0.85rem; text-align: left;
    background: var(--s-surface); border-radius: 9999px; padding: 0.5rem 1.5rem 0.5rem 0.5rem;
    box-shadow: 0 18px 45px -30px rgba(0, 0, 0, 0.4);
    transition: transform 0.45s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .ri-chip:hover { transform: translateY(-4px); }
  .ri-chip .st-avatar { height: 2.9rem; width: 2.9rem; font-size: 15px; }

  /* --- radno vreme: talasasto podvučen "danas" -------------------------------- */
  .ri-hours { max-width: 23rem; margin-inline: auto; }
  .ri-hours-row { display: flex; justify-content: space-between; gap: 1rem; padding: 0.62rem 0.4rem; font-size: 14px; font-variant-numeric: tabular-nums; }
  .ri-hours-row + .ri-hours-row { border-top: 1px solid var(--s-line); }
  .ri-hours-row.today { color: var(--brand); font-weight: 600; }
  .ri-hours-row.today .ri-day { text-decoration: underline wavy; text-decoration-color: color-mix(in srgb, var(--brand) 55%, transparent); text-underline-offset: 5px; }

  .ri-phone { font-family: var(--s-display); font-weight: var(--s-display-weight); font-size: clamp(2rem, 6vw, 3.2rem); color: var(--s-ink); text-decoration: none; transition: color 0.3s; font-variant-numeric: tabular-nums; }
  .ri-phone:hover { color: var(--brand); }

  @media (prefers-reduced-motion: reduce) {
    .ri-slow { opacity: 1 !important; transform: none !important; }
    .ri-sun { opacity: 1 !important; transform: translateX(-50%) !important; }
  }
</style>
{% endblock %}

{% block content %}
<div class="site st-grain">

  {% if demo %}{{ shared.demoBar(layoutList, themeList, layout, theme) }}{% endif %}

  <!-- Navigacija -->
  <nav class="ri-nav" data-nav>
    <div class="ri-wrap" style="display:flex;align-items:center;justify-content:space-between;gap:1rem;height:4.25rem">
      <a href="#vrh" style="text-decoration:none;color:inherit"><span class="st-serif" style="font-size:17px">{{ site.name }}</span></a>
      <a class="st-btn st-btn-gold st-btn-shine" style="height:2.75rem;padding-inline:1.2rem;font-size:13px" href="tel:{{ site.phoneRaw }}">Zakaži</a>
    </div>
  </nav>

  <!-- Hero: sunce izlazi -->
  <header class="ri-hero" id="vrh" data-hero>
    <div class="ri-sun" aria-hidden="true"></div>
    <p class="st-kicker ri-slow"><span class="ri-pulse" aria-hidden="true"></span>{{ site.tagline }}</p>
    <h1 class="st-serif ri-h1 ri-slow" style="--d:.15s;margin-top:1.4rem">Jutro koje počinje <em>tobom.</em></h1>
    <p class="ri-slow" style="--d:.32s;margin-top:1.5rem;max-width:30rem;color:var(--s-muted);font-size:16px;line-height:1.7">{{ site.about }}</p>
    <div class="ri-slow" style="--d:.5s;margin-top:2.4rem;display:flex;flex-wrap:wrap;gap:.9rem;justify-content:center">
      <a class="st-btn st-btn-gold st-btn-shine" href="tel:{{ site.phoneRaw }}">Zakaži termin</a>
      <a class="st-btn st-btn-ghost" href="#ritual">Kako izgleda poseta</a>
    </div>
  </header>

  <!-- Ritual: o nama u tri koraka -->
  <section class="ri-section" id="ritual">
    <div class="ri-orb" aria-hidden="true" style="top:10%;left:-4rem;width:16rem;height:16rem;background:var(--s-aurora1)"></div>
    <div class="ri-wrap" style="text-align:center">
      <p class="st-kicker rev">Ritual</p>
      <h2 class="st-serif ri-h2 rev" style="margin-top:1rem">Svaka poseta — <em>mali ritual.</em></h2>
      <p class="rev" style="margin-top:1.4rem;margin-inline:auto;max-width:36rem;color:var(--s-muted);font-size:16px;line-height:1.75">{{ site.aboutLong }}</p>
      <div class="ri-steps" style="margin-top:3rem">
        <div class="ri-step rev">
          <p class="ri-step-n">01 — DOLAZAK</p>
          <p style="margin-top:.4rem;font-size:16px;font-weight:600">Dogovor uz kafu</p>
          <p style="margin-top:.3rem;font-size:14px;color:var(--s-muted);line-height:1.65">Kratko pričamo o tome šta želiš — i šta tvoja kosa i koža stvarno traže.</p>
        </div>
        <div class="ri-step rev" style="--d:.12s">
          <p class="ri-step-n">02 — NEGA</p>
          <p style="margin-top:.4rem;font-size:16px;font-weight:600">Ritual nege</p>
          <p style="margin-top:.3rem;font-size:14px;color:var(--s-muted);line-height:1.65">Bez žurbe i bez telefona koji zvoni pored uva — vreme je samo tvoje.</p>
        </div>
        <div class="ri-step rev" style="--d:.24s">
          <p class="ri-step-n">03 — SJAJ</p>
          <p style="margin-top:.4rem;font-size:16px;font-weight:600">Završni sjaj</p>
          <p style="margin-top:.3rem;font-size:14px;color:var(--s-muted);line-height:1.65">Odlaziš sa stilom koji umeš sama da ponoviš — pokažemo ti kako.</p>
        </div>
      </div>
      <div style="margin-top:3rem;display:flex;justify-content:center;flex-wrap:wrap;gap:2.6rem">
        {% for f in site.facts %}
        <div class="rev" style="--d:{{ loop.index0 * 0.12 }}s">
          <p class="st-serif" style="font-size:2rem;color:var(--brand)">{{ f.n }}</p>
          <p style="font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:var(--s-muted);margin-top:.2rem">{{ f.label }}</p>
        </div>
        {% endfor %}
      </div>
    </div>
  </section>

  <!-- Cenovnik: plutajuće ostrvo -->
  <section class="ri-section" id="cenovnik" style="padding-top:1rem">
    <div class="ri-wrap">
      <div class="ri-isle rev">
        <div style="text-align:center">
          <p class="st-kicker">Cenovnik</p>
          <h2 class="st-serif ri-h2" style="margin-top:1rem">Jasne cene. <em>Bez zvezdica.</em></h2>
        </div>
        <div class="ri-menu" style="margin-top:2.2rem">
          {% for s in services %}
          <div class="ri-row">
            <div>
              <p style="font-size:15px;font-weight:600">{{ s.name }}</p>
              <p style="font-size:11px;color:var(--s-muted);margin-top:.15rem">{{ s.durationMin }} min</p>
            </div>
            <span class="ri-row-val">{{ s.price }}</span>
          </div>
          {% endfor %}
        </div>
        <p style="margin-top:1.6rem;text-align:center;font-size:13px;color:var(--s-muted)">Cene su informativne — za duže tretmane javi nam se porukom pre termina.</p>
      </div>
    </div>
  </section>

  <!-- Galerija: dve kolone u raskoraku -->
  <section class="ri-section" id="galerija">
    <div class="ri-orb" aria-hidden="true" style="top:0;right:-5rem;width:18rem;height:18rem;background:var(--s-aurora2)"></div>
    <div class="ri-wrap">
      <div style="text-align:center">
        <p class="st-kicker rev">Galerija</p>
        <h2 class="st-serif ri-h2 rev" style="margin-top:1rem">Mir se <em>vidi.</em></h2>
      </div>
      <div class="ri-gal" style="margin-top:2.8rem">
        {% for g in gallery %}
        <div class="st-tile rev" style="--d:{{ loop.index0 * 0.08 }}s">
          <div class="st-tile-art" style="background:{{ g.art }}"></div>
          <span class="st-tile-label">{{ g.label }}</span>
        </div>
        {% endfor %}
      </div>
    </div>
  </section>

  <!-- Tim: pilule -->
  <section class="ri-section" id="tim" style="padding-top:2rem">
    <div class="ri-wrap" style="text-align:center">
      <p class="st-kicker rev">Tim</p>
      <h2 class="st-serif ri-h2 rev" style="margin-top:1rem">Ruke od poverenja.</h2>
      <div class="ri-team" style="margin-top:2.4rem">
        {% for m in staff %}
        <div class="ri-chip rev" style="--d:{{ loop.index0 * 0.1 }}s">
          <span class="st-avatar st-serif" style="background:{{ m.color }}">{{ m.initials }}</span>
          <span>
            <span style="display:block;font-size:14px;font-weight:600">{{ m.name }}</span>
            <span style="display:block;font-size:12px;color:var(--s-muted)">{{ m.role }}</span>
          </span>
        </div>
        {% endfor %}
      </div>
    </div>
  </section>

  <!-- Radno vreme + kontakt: plutajuće ostrvo -->
  <section class="ri-section" id="kontakt" style="padding-top:2rem;padding-bottom:3rem">
    <div class="ri-wrap">
      <div class="ri-isle rev" style="text-align:center">
        <p class="st-kicker">Radno vreme</p>
        <div class="ri-hours" style="margin-top:1.5rem">
          {% for h in hours %}
          <div class="ri-hours-row {% if h.today %}today{% endif %}">
            <span class="ri-day">{{ h.label }}</span>
            <span style="{% if not h.open %}color:var(--s-muted){% endif %}">{{ h.time }}</span>
          </div>
          {% endfor %}
        </div>

        <p class="st-kicker" style="margin-top:3rem">Kontakt</p>
        <h2 class="st-serif ri-h2" style="margin-top:1rem">Vidimo se <em>u salonu.</em></h2>
        <a class="ri-phone" style="display:inline-block;margin-top:1.2rem" href="tel:{{ site.phoneRaw }}">{{ site.phone }}</a>
        <p style="margin-top:.8rem;color:var(--s-muted);font-size:14px">
          <a href="https://www.google.com/maps/search/{{ site.address | urlencode }}" target="_blank" rel="noopener" style="color:inherit">{{ site.address }}</a>
        </p>
        <div style="margin-top:1.8rem;display:flex;flex-wrap:wrap;gap:.9rem;justify-content:center">
          <a class="st-btn st-btn-gold st-btn-shine" href="tel:{{ site.phoneRaw }}">Pozovi salon</a>
          <a class="st-btn st-btn-ghost" href="https://instagram.com/{{ site.instagram }}" target="_blank" rel="noopener">@{{ site.instagram }}</a>
        </div>
      </div>
    </div>
  </section>

  {{ shared.footer(site, year) }}
  {{ shared.ctaBar(site) }}
</div>

{{ shared.baseJs() }}
{% endblock %}
