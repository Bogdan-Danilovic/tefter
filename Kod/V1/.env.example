# App runtime — konektuje se kao NON-owner rola, RLS je aktivan.
# Svaki request unutar transakcije radi SET LOCAL app.current_salon_id = '<uuid>'.
DATABASE_URL=postgres://tefter_app:change_me@localhost:5432/tefter

# Migracije + seed — superuser, zaobilazi RLS (potreban za CREATE ROLE / policies / seed).
MIGRATION_DATABASE_URL=postgres://postgres:postgres@localhost:5432/tefter

# Lozinka koju 0001_rls.sql postavlja za tefter_app rolu (mora da se poklopi sa DATABASE_URL).
APP_DB_PASSWORD=change_me

# Tajna za potpisivanje session cookie-ja (HMAC-SHA256). Obavezno; generiši npr:
#   node -e "console.log(crypto.randomBytes(32).toString('hex'))"
SESSION_SECRET=change_me_too
